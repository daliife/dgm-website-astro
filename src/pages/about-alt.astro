---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import PageContainer from "../components/PageContainer.astro";
import Typography from "../components/Typography.astro";
import { skills, languages, interests } from "@cv";
import { TITLE_PAGE_PREFIX } from "../utils/constants";
---

<Layout
  title={`${TITLE_PAGE_PREFIX} About`}
  description="Learn more about David Gimeno's background, experience, and professional journey as a Software Engineer."
>
  <PageContainer type="narrow">
    <!-- Personal Journey Section -->
    <Section id="journey" title="My Journey">
      <div class="max-w-4xl mx-auto">
        <div
          class="bg-gradient-to-br from-primary-500/5 to-secondary-500/5 rounded-2xl p-8 border border-primary-500/20 mb-8"
        >
          <Typography
            variant="h3"
            color="primary"
            align="center"
            className="mb-6"
          >
            From Multimedia to Software Engineering
          </Typography>
          <Typography
            variant="body"
            color="secondary"
            align="center"
            className="text-pretty leading-relaxed"
          >
            My path started in multimedia engineering, where I discovered my
            passion for creating digital experiences. Through 3D modeling, game
            development with Unity, and web design, I found my calling in
            software engineering. Each project taught me something new and
            shaped my approach to problem-solving.
          </Typography>
        </div>
      </div>
    </Section>

    <!-- Skills Section -->
    <Section id="skills" title="Skills & Expertise">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          skills.map(skill => (
            <div class="bg-bg-secondary/30 backdrop-blur-sm rounded-xl p-6 border border-border-primary/20">
              <h3 class="text-text-primary text-lg font-semibold mb-4">
                {skill.name}
              </h3>
              <div class="mb-4">
                <div class="flex justify-between text-sm text-text-secondary mb-2">
                  <span>Level</span>
                  <span>{skill.level}</span>
                </div>
                <div class="w-full bg-bg-muted/50 rounded-full h-2">
                  <div
                    class="bg-gradient-to-r from-primary-500 to-secondary-500 h-2 rounded-full transition-all duration-1000"
                    style={`width: ${skill.level === "Master" ? "100%" : skill.level === "Expert" ? "90%" : skill.level === "Advanced" ? "75%" : skill.level === "Intermediate" ? "60%" : "40%"}`}
                  />
                </div>
              </div>
              <div class="flex flex-wrap gap-2">
                {skill.keywords.map(keyword => (
                  <span class="px-3 py-1 bg-primary-500/10 text-primary-600 dark:text-primary-400 text-sm rounded-full border border-primary-500/20">
                    {keyword}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </Section>

    <!-- Languages Section -->
    <Section id="languages" title="Languages">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          languages.map(lang => (
            <div class="text-center p-6 bg-bg-secondary/20 backdrop-blur-sm rounded-xl border border-border-primary/20">
              <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-gradient-to-br from-primary-400 to-secondary-400 flex items-center justify-center">
                <span class="text-2xl font-bold text-white">
                  {lang.language.charAt(0)}
                </span>
              </div>
              <h3 class="text-text-primary font-semibold mb-2">
                {lang.language}
              </h3>
              <p class="text-text-secondary text-sm">{lang.fluency}</p>
            </div>
          ))
        }
      </div>
    </Section>

    <!-- Interests Section -->
    <Section id="interests" title="Interests">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {
          interests.map(interest => (
            <div class="bg-bg-secondary/30 backdrop-blur-sm rounded-xl p-6 border border-border-primary/20">
              <h3 class="text-text-primary text-lg font-semibold mb-4 flex items-center">
                <span class="w-8 h-8 rounded-full bg-gradient-to-br from-primary-500 to-secondary-500 flex items-center justify-center text-white text-sm font-bold mr-3">
                  {interest.name.charAt(0)}
                </span>
                {interest.name}
              </h3>
              <div class="flex flex-wrap gap-2">
                {interest.keywords.map(keyword => (
                  <span class="px-3 py-1 bg-secondary-500/10 text-secondary-600 dark:text-secondary-400 text-sm rounded-full border border-secondary-500/20">
                    {keyword}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </Section>

    <!-- Work Philosophy Section -->
    <Section id="philosophy" title="My Work Philosophy">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div
          class="bg-bg-secondary/30 backdrop-blur-sm rounded-xl p-6 border border-border-primary/20"
        >
          <div
            class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-secondary-500 flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
              ></path>
            </svg>
          </div>
          <h3 class="text-text-primary text-lg font-semibold mb-3">
            Problem-Solving First
          </h3>
          <p class="text-text-secondary text-sm leading-relaxed">
            I believe technology should solve real problems. Every line of code
            I write is driven by the question: "How does this make someone's
            life better or easier?"
          </p>
        </div>

        <div
          class="bg-bg-secondary/30 backdrop-blur-sm rounded-xl p-6 border border-border-primary/20"
        >
          <div
            class="w-12 h-12 rounded-full bg-gradient-to-br from-secondary-500 to-primary-500 flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
              ></path>
            </svg>
          </div>
          <h3 class="text-text-primary text-lg font-semibold mb-3">
            Continuous Learning
          </h3>
          <p class="text-text-secondary text-sm leading-relaxed">
            The tech world evolves rapidly, and so do I. I'm always exploring
            new frameworks, methodologies, and best practices to stay current
            and deliver better solutions.
          </p>
        </div>
      </div>
    </Section>

    <!-- Personal Interests Section -->
    <Section id="interests" title="Beyond the Screen">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div
          class="bg-bg-secondary/30 backdrop-blur-sm rounded-xl p-6 border border-border-primary/20"
        >
          <h3
            class="text-text-primary text-lg font-semibold mb-4 flex items-center"
          >
            <span
              class="w-8 h-8 rounded-full bg-gradient-to-br from-primary-500 to-secondary-500 flex items-center justify-center text-white text-sm font-bold mr-3"
            >
              🎮
            </span>
            Gaming & Interactive Media
          </h3>
          <p class="text-text-secondary text-sm leading-relaxed mb-4">
            I love creating interactive experiences, from Unity games to
            web-based minigames. There's something magical about bringing ideas
            to life through code and seeing people enjoy them.
          </p>
          <div class="flex flex-wrap gap-2">
            <span
              class="px-3 py-1 bg-primary-500/10 text-primary-600 dark:text-primary-400 text-sm rounded-full border border-primary-500/20"
            >
              Unity Development
            </span>
            <span
              class="px-3 py-1 bg-primary-500/10 text-primary-600 dark:text-primary-400 text-sm rounded-full border border-primary-500/20"
            >
              Game Design
            </span>
            <span
              class="px-3 py-1 bg-primary-500/10 text-primary-600 dark:text-primary-400 text-sm rounded-full border border-primary-500/20"
            >
              Interactive Web
            </span>
          </div>
        </div>

        <div
          class="bg-bg-secondary/30 backdrop-blur-sm rounded-xl p-6 border border-border-primary/20"
        >
          <h3
            class="text-text-primary text-lg font-semibold mb-4 flex items-center"
          >
            <span
              class="w-8 h-8 rounded-full bg-gradient-to-br from-secondary-500 to-primary-500 flex items-center justify-center text-white text-sm font-bold mr-3"
            >
              🎨
            </span>
            Creative Expression
          </h3>
          <p class="text-text-secondary text-sm leading-relaxed mb-4">
            My multimedia background gives me a unique perspective on design and
            user experience. I enjoy the intersection of technology and
            creativity, where code meets art.
          </p>
          <div class="flex flex-wrap gap-2">
            <span
              class="px-3 py-1 bg-secondary-500/10 text-secondary-600 dark:text-secondary-400 text-sm rounded-full border border-secondary-500/20"
            >
              3D Modeling
            </span>
            <span
              class="px-3 py-1 bg-secondary-500/10 text-secondary-600 dark:text-secondary-400 text-sm rounded-full border border-secondary-500/20"
            >
              UI/UX Design
            </span>
            <span
              class="px-3 py-1 bg-secondary-500/10 text-secondary-600 dark:text-secondary-400 text-sm rounded-full border border-secondary-500/20"
            >
              Visual Storytelling
            </span>
          </div>
        </div>
      </div>
    </Section>

    <!-- Fun Facts Section -->
    <Section id="fun-facts" title="Fun Facts">
      <div
        class="bg-gradient-to-br from-primary-500/5 to-secondary-500/5 rounded-2xl p-8 border border-primary-500/20"
      >
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="text-center">
            <div
              class="w-16 h-16 mx-auto mb-4 rounded-full bg-gradient-to-br from-primary-500 to-secondary-500 flex items-center justify-center"
            >
              <span class="text-2xl font-bold text-white">∞</span>
            </div>
            <h4 class="text-text-primary font-semibold mb-2">Perfectionist</h4>
            <p class="text-text-secondary text-sm">
              I won't ship until it's perfect
            </p>
          </div>

          <div class="text-center">
            <div
              class="w-16 h-16 mx-auto mb-4 rounded-full bg-gradient-to-br from-secondary-500 to-primary-500 flex items-center justify-center"
            >
              <span class="text-2xl font-bold text-white">⚡</span>
            </div>
            <h4 class="text-text-primary font-semibold mb-2">Quick Learner</h4>
            <p class="text-text-secondary text-sm">
              New technologies excite me
            </p>
          </div>

          <div class="text-center">
            <div
              class="w-16 h-16 mx-auto mb-4 rounded-full bg-gradient-to-br from-primary-500 to-secondary-500 flex items-center justify-center"
            >
              <span class="text-2xl font-bold text-white">🎯</span>
            </div>
            <h4 class="text-text-primary font-semibold mb-2">Goal-Oriented</h4>
            <p class="text-text-secondary text-sm">
              I always have a clear vision
            </p>
          </div>
        </div>
      </div>
    </Section>
  </PageContainer>
</Layout>
