---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import Timeline from "../components/Timeline.astro";
import PageContainer from "../components/PageContainer.astro";
import { work } from "@cv";
import { TITLE_PAGE_PREFIX } from "../utils/constants";

const workExperience = work.map(job => {
  return {
    startDate: job.startDate,
    endDate: job.endDate,
    title: job.position,
    description: job.summary,
    link: job.url,
    company: job.company,
    highlights: job.highlights,
  };
});
---

<Layout
  title={`${TITLE_PAGE_PREFIX} Work`}
  description="David Gimeno's professional work experience, including roles at NTT Data and other companies in software development."
>
  <PageContainer type="narrow">
    <Section id="work" title="Work">
      <Timeline elements={workExperience} />
    </Section>
  </PageContainer>
</Layout>
