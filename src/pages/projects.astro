---
import Layout from "../layouts/Layout.astro";
import {
  TITLE_PAGE_PREFIX,
  PAGE_CONTAINER_CLASSES,
  PAGE_HEADING_CLASSES,
  LIVE_URL,
} from "../utils/constants";
import { SITE_BASE } from "../utils/url";
import { projects } from "@cv";
import ProjectCard from "../components/sections/ProjectCard.astro";
import type { ProjectEntry } from "../types/ui";

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Projects Portfolio",
  description: "Portfolio of web development projects by David Gimeno Mañé.",
  url: `${LIVE_URL}/projects`,
  itemListElement: projects.map((p: ProjectEntry, i: number) => ({
    "@type": "ListItem",
    position: i + 1,
    name: p.name,
    description: p.description,
    ...(p.url ? { url: p.url } : {}),
  })),
};
---

<Layout
  title={`Projects Portfolio${TITLE_PAGE_PREFIX}`}
  description="Portfolio of web development projects by David Gimeno Mañé — Frontend Developer based in Barcelona."
>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(itemListSchema)}
  />
  <div class={PAGE_CONTAINER_CLASSES}>
    <h1 class={`${PAGE_HEADING_CLASSES} mb-12`} data-i18n="ui.page.projects">
      Projects
    </h1>
    <div class="space-y-0 reveal">
      {
        projects.map((project: ProjectEntry, i: number) => (
          <ProjectCard {project} projectIndex={i} />
        ))
      }
    </div>

    <nav
      aria-label="Related pages"
      class="border-t border-border-primary pt-8 mt-4 reveal"
    >
      <p
        class="text-xs uppercase tracking-widest text-text-muted mb-5"
        data-i18n="ui.nextup"
      >
        Also explore
      </p>
      <div class="flex flex-col sm:flex-row gap-5 sm:gap-8">
        <a
          href={`${SITE_BASE}/work`}
          class="text-sm uppercase tracking-widest text-text-primary border-b border-border-secondary hover:border-text-primary pb-1 transition-colors duration-200 w-fit"
          data-i18n="ui.nextup.work">My work experience</a
        >
        <a
          href={`${SITE_BASE}/contact`}
          class="text-sm uppercase tracking-widest text-text-primary border-b border-border-secondary hover:border-text-primary pb-1 transition-colors duration-200 w-fit"
          data-i18n="ui.nextup.contact">Contact</a
        >
      </div>
    </nav>
  </div>
</Layout>
