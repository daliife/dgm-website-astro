---
import Layout from "../layouts/Layout.astro";
import {
  TITLE_PAGE_SUFFIX,
  PAGE_CONTAINER_CLASSES,
  PAGE_HEADING_CLASSES,
  LIVE_URL,
} from "../utils/constants";
import { SITE_BASE } from "../utils/url";
import { projects } from "@cv";
import ProjectCard from "../components/sections/ProjectCard.astro";
import Button from "../components/ui/Button.astro";
import type { ProjectEntry } from "../types/ui";

const CATEGORY_ORDER = ["professional", "personal", "academic"] as const;
type Category = (typeof CATEGORY_ORDER)[number];

const CATEGORY_LABELS: Record<Category, string> = {
  professional: "Professional",
  personal: "Personal",
  academic: "Academic",
};

const CATEGORY_I18N: Record<Category, string> = {
  professional: "ui.projects.category.professional",
  personal: "ui.projects.category.personal",
  academic: "ui.projects.category.academic",
};

const indexed = (projects as ProjectEntry[]).map((project, index) => ({
  project,
  index,
}));

const grouped: Record<Category, { project: ProjectEntry; index: number }[]> = {
  professional: indexed.filter(
    ({ project }) => project.category === "professional",
  ),
  personal: indexed.filter(({ project }) => project.category === "personal"),
  academic: indexed.filter(({ project }) => project.category === "academic"),
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Projects Portfolio",
  description: "Portfolio of web development projects by David Gimeno Mañé.",
  url: `${LIVE_URL}/projects`,
  itemListElement: (projects as ProjectEntry[]).map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: p.name,
    description: p.description,
    ...(p.url ? { url: p.url } : {}),
  })),
};
---

<Layout
  title={`Projects Portfolio${TITLE_PAGE_SUFFIX}`}
  description="Portfolio of web development projects by David Gimeno Mañé — Frontend Developer based in Barcelona."
>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(itemListSchema)}
  />
  <div class={PAGE_CONTAINER_CLASSES}>
    <h1 class={`${PAGE_HEADING_CLASSES} mb-12`} data-i18n="ui.page.projects">
      Projects
    </h1>
    {
      CATEGORY_ORDER.map(
        (cat) =>
          grouped[cat].length > 0 && (
            <section class="reveal">
              <p
                class="pb-0 pt-8 text-xs uppercase tracking-widest text-text-muted"
                data-i18n={CATEGORY_I18N[cat]}
              >
                {CATEGORY_LABELS[cat]}
              </p>
              <div class="space-y-0">
                {grouped[cat].map(({ project, index }) => (
                  <ProjectCard {project} projectIndex={index} />
                ))}
              </div>
            </section>
          ),
      )
    }

    <nav
      aria-label="Related pages"
      class="reveal mt-4 border-t border-border-primary pt-8"
    >
      <p
        class="mb-5 text-xs uppercase tracking-widest text-text-muted"
        data-i18n="ui.nextup"
      >
        Also explore
      </p>
      <div class="flex flex-col gap-5 sm:flex-row sm:gap-8">
        <Button
          href={`${SITE_BASE}/work`}
          variant="simple"
          size="none"
          className="w-fit rounded-none border-b border-border-secondary pb-1 text-sm uppercase tracking-widest text-text-primary hover:border-text-primary hover:no-underline"
        >
          <span data-i18n="ui.nextup.work">My work experience</span>
        </Button>
        <Button
          href={`${SITE_BASE}/contact`}
          variant="simple"
          size="none"
          className="w-fit rounded-none border-b border-border-secondary pb-1 text-sm uppercase tracking-widest text-text-primary hover:border-text-primary hover:no-underline"
        >
          <span data-i18n="ui.nextup.contact">Contact</span>
        </Button>
      </div>
    </nav>
  </div>
</Layout>
