---
import Layout from "../layouts/Layout.astro";
import {
  TITLE_PAGE_SUFFIX,
  PAGE_CONTAINER_CLASSES,
  PAGE_HEADING_CLASSES,
  PAGE_HEADING_MARGIN_CLASSES,
  LIVE_URL,
} from "../utils/constants";
import { SITE_BASE } from "../utils/url";
import { t } from "../utils/i18n";
import { projects } from "@cv";
import ProjectCard from "../components/sections/ProjectCard.astro";
import NextUpNav from "../components/layout/NextUpNav.astro";
import type { ProjectEntry } from "../types/ui";

const CATEGORY_ORDER = ["professional", "personal", "academic"] as const;
type Category = (typeof CATEGORY_ORDER)[number];

const CATEGORY_ICON_PATHS: Record<Category, string> = {
  professional: `<rect x="2" y="7" width="20" height="14" rx="2" ry="2" /><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />`,
  personal: `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" />`,
  academic: `<path d="M22 10v6M2 10l10-5 10 5-10 5z" /><path d="M6 12v5c3 3 9 3 12 0v-5" />`,
};

const CATEGORY_LABELS: Record<Category, string> = {
  professional: t("ui.projects.category.professional"),
  personal: t("ui.projects.category.personal"),
  academic: t("ui.projects.category.academic"),
};

const CATEGORY_I18N: Record<Category, string> = {
  professional: "ui.projects.category.professional",
  personal: "ui.projects.category.personal",
  academic: "ui.projects.category.academic",
};

const indexed = (projects as ProjectEntry[]).map((project, index) => ({
  project,
  index,
}));

const grouped: Record<Category, { project: ProjectEntry; index: number }[]> = {
  professional: indexed.filter(
    ({ project }) => project.category === "professional",
  ),
  personal: indexed.filter(({ project }) => project.category === "personal"),
  academic: indexed.filter(({ project }) => project.category === "academic"),
};

const firstVisibleProjectIndex = CATEGORY_ORDER.flatMap(
  (cat) => grouped[cat],
).find(Boolean)?.index;

const firstCategory = CATEGORY_ORDER.find((cat) => grouped[cat].length > 0);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Projects Portfolio",
  description: "Portfolio of web development projects by David Gimeno Mañé.",
  url: `${LIVE_URL}/projects`,
  itemListElement: (projects as ProjectEntry[]).map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: p.name,
    description: p.description,
    ...(p.url ? { url: p.url } : {}),
  })),
};
---

<Layout
  title={`Projects Portfolio${TITLE_PAGE_SUFFIX}`}
  description="Portfolio of web development projects by David Gimeno Mañé — Frontend Developer based in Barcelona."
>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(itemListSchema)}
  />
  <div class={PAGE_CONTAINER_CLASSES}>
    <h1
      class={`${PAGE_HEADING_CLASSES} ${PAGE_HEADING_MARGIN_CLASSES}`}
      data-i18n="ui.page.projects"
    >
      {t("ui.page.projects")}
    </h1>
    {
      CATEGORY_ORDER.map(
        (cat) =>
          grouped[cat].length > 0 && (
            <section
              class="reveal"
              aria-labelledby={`projects-category-${cat}`}
            >
              <header
                class:list={["pb-3", cat === firstCategory ? "pt-2" : "pt-12"]}
              >
                <h2
                  id={`projects-category-${cat}`}
                  class="text-sm sm:text-base"
                >
                  <span class="inline-flex items-center gap-2 rounded-full border border-border-secondary bg-bg-secondary px-3 py-1.5 text-xs font-medium uppercase tracking-wide text-text-primary sm:gap-2.5 sm:px-4 sm:py-2 sm:text-sm">
                    <svg
                      class="h-3.5 w-3.5 shrink-0 sm:h-4 sm:w-4"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <Fragment set:html={CATEGORY_ICON_PATHS[cat]} />
                    </svg>
                    <span data-i18n={CATEGORY_I18N[cat]}>
                      {CATEGORY_LABELS[cat]}
                    </span>
                  </span>
                </h2>
              </header>
              <ul class="list-none space-y-0 [&>li:first-child>article]:border-t-0">
                {grouped[cat].map(({ project, index }) => (
                  <li>
                    <ProjectCard
                      {project}
                      projectIndex={index}
                      priority={index === firstVisibleProjectIndex}
                    />
                  </li>
                ))}
              </ul>
            </section>
          ),
      )
    }

    <NextUpNav
      links={[
        { href: `${SITE_BASE}/work`, labelKey: "ui.nextup.work" },
        { href: `${SITE_BASE}/contact`, labelKey: "ui.nextup.contact" },
      ]}
    />
  </div>
</Layout>
