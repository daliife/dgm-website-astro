---
import Layout from "../layouts/Layout.astro";
import { TITLE_PAGE_PREFIX } from "../utils/constants";
import { projects } from "@cv";
import type { ProjectEntry } from "../types/ui";
---

<Layout
  title={`${TITLE_PAGE_PREFIX}Projects`}
  description="Portfolio of web development projects by David Gimeno."
>
  <div class="max-w-5xl mx-auto px-6 pt-32 pb-20">
    <h1
      class="text-4xl sm:text-5xl font-bold tracking-tight text-text-primary uppercase mb-12 reveal"
    >
      Projects
    </h1>
    <div class="space-y-0 reveal">
      {
        projects.map((project: ProjectEntry) => (
          <article class="group border-t border-border-primary py-8">
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col sm:flex-row gap-6 sm:gap-10 items-start"
            >
              {/* Project image */}
              <div class="w-full sm:w-48 sm:shrink-0 h-28 sm:h-32 rounded-lg overflow-hidden bg-bg-muted">
                <img
                  src={
                    project.image ??
                    "https://placehold.co/384x256/e5e5e5/d4d4d4"
                  }
                  alt={project.name}
                  class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-[1.04] transition-all duration-700 ease-out"
                  loading="lazy"
                  width="384"
                  height="256"
                  onerror="this.onerror=null;this.src='https://placehold.co/384x256/e5e5e5/d4d4d4'"
                />
              </div>
              {/* Content */}
              <div class="flex-1 min-w-0">
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2 mb-3">
                  <h2 class="text-xl sm:text-2xl font-semibold text-text-primary group-hover:opacity-60 transition-all duration-700 ease-out">
                    {project.name}
                  </h2>
                  <span class="text-xs uppercase tracking-widest text-text-muted whitespace-nowrap">
                    {project.technologies?.join(" · ")}
                  </span>
                </div>
                <p class="text-text-secondary text-sm sm:text-base leading-relaxed">
                  {project.description}
                </p>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</Layout>
