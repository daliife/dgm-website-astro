---
import Layout from "../layouts/Layout.astro";
import {
  TITLE_PAGE_SUFFIX,
  PAGE_CONTAINER_CLASSES,
  PAGE_HEADING_CLASSES,
} from "../utils/constants";
import { t } from "../utils/i18n";

const PRIVACY_LIST_ITEM =
  "flex items-start gap-2.5 text-sm leading-relaxed text-text-secondary";
---

<Layout title={`Privacy Policy${TITLE_PAGE_SUFFIX}`}>
  <div class={PAGE_CONTAINER_CLASSES}>
    <h1 class={`${PAGE_HEADING_CLASSES} mb-12`} data-i18n="ui.page.privacy">
      {t("ui.page.privacy")}
    </h1>

    <div class="max-w-2xl space-y-10">
      <p class="reveal text-base leading-relaxed text-text-secondary">
        <span data-i18n="ui.privacy.intro.before"
          >{t("ui.privacy.intro.before")}</span
        ><a
          href="https://umami.is"
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-primary underline underline-offset-4 transition-opacity hover:opacity-70"
          >Umami<span class="sr-only" data-i18n="ui.a11y.opensNewTab">
            {t("ui.a11y.opensNewTab")}
          </span></a
        ><span data-i18n="ui.privacy.intro.after"
          >{t("ui.privacy.intro.after")}</span
        >
      </p>

      <section class="reveal">
        <h2
          class="mb-3 text-lg font-semibold uppercase tracking-wide text-text-primary"
          data-i18n="ui.privacy.collected.title"
        >
          {t("ui.privacy.collected.title")}
        </h2>
        <ul class="space-y-2">
          <li class={PRIVACY_LIST_ITEM}>
            <span class="mt-0.5 shrink-0 text-text-muted" aria-hidden="true"
              >–</span
            >
            <span data-i18n="ui.privacy.collected.0">
              {t("ui.privacy.collected.0")}
            </span>
          </li>
          <li class={PRIVACY_LIST_ITEM}>
            <span class="mt-0.5 shrink-0 text-text-muted" aria-hidden="true"
              >–</span
            >
            <span data-i18n="ui.privacy.collected.1">
              {t("ui.privacy.collected.1")}
            </span>
          </li>
          <li class={PRIVACY_LIST_ITEM}>
            <span class="mt-0.5 shrink-0 text-text-muted" aria-hidden="true"
              >–</span
            >
            <span data-i18n="ui.privacy.collected.2">
              {t("ui.privacy.collected.2")}
            </span>
          </li>
          <li class={PRIVACY_LIST_ITEM}>
            <span class="mt-0.5 shrink-0 text-text-muted" aria-hidden="true"
              >–</span
            >
            <span data-i18n="ui.privacy.collected.3">
              {t("ui.privacy.collected.3")}
            </span>
          </li>
          <li class={PRIVACY_LIST_ITEM}>
            <span class="mt-0.5 shrink-0 text-text-muted" aria-hidden="true"
              >–</span
            >
            <span data-i18n="ui.privacy.collected.4">
              {t("ui.privacy.collected.4")}
            </span>
          </li>
        </ul>
      </section>

      <section class="reveal">
        <h2
          class="mb-3 text-lg font-semibold uppercase tracking-wide text-text-primary"
          data-i18n="ui.privacy.notcollected.title"
        >
          {t("ui.privacy.notcollected.title")}
        </h2>
        <ul class="space-y-2">
          <li class={PRIVACY_LIST_ITEM}>
            <span class="mt-0.5 shrink-0 text-text-muted" aria-hidden="true"
              >–</span
            >
            <span data-i18n="ui.privacy.notcollected.0">
              {t("ui.privacy.notcollected.0")}
            </span>
          </li>
          <li class={PRIVACY_LIST_ITEM}>
            <span class="mt-0.5 shrink-0 text-text-muted" aria-hidden="true"
              >–</span
            >
            <span data-i18n="ui.privacy.notcollected.1">
              {t("ui.privacy.notcollected.1")}
            </span>
          </li>
          <li class={PRIVACY_LIST_ITEM}>
            <span class="mt-0.5 shrink-0 text-text-muted" aria-hidden="true"
              >–</span
            >
            <span data-i18n="ui.privacy.notcollected.2">
              {t("ui.privacy.notcollected.2")}
            </span>
          </li>
          <li class={PRIVACY_LIST_ITEM}>
            <span class="mt-0.5 shrink-0 text-text-muted" aria-hidden="true"
              >–</span
            >
            <span data-i18n="ui.privacy.notcollected.3">
              {t("ui.privacy.notcollected.3")}
            </span>
          </li>
          <li class={PRIVACY_LIST_ITEM}>
            <span class="mt-0.5 shrink-0 text-text-muted" aria-hidden="true"
              >–</span
            >
            <span data-i18n="ui.privacy.notcollected.4">
              {t("ui.privacy.notcollected.4")}
            </span>
          </li>
        </ul>
      </section>

      <p class="reveal text-sm text-text-muted">
        <span data-i18n="ui.privacy.moreinfo">{t("ui.privacy.moreinfo")}</span>{
          " "
        }
        <a
          href="https://umami.is/privacy"
          target="_blank"
          rel="noopener noreferrer"
          class="underline underline-offset-4 transition-colors hover:text-text-secondary"
          >umami.is/privacy ↗<span
            class="sr-only"
            data-i18n="ui.a11y.opensNewTab"
          >
            {t("ui.a11y.opensNewTab")}
          </span></a
        >.
      </p>
    </div>
  </div>
</Layout>
