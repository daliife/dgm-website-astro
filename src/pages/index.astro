---
import Layout from "../layouts/Layout.astro";
import HomeContainer from "../components/HomeContainer.astro";
import Typography from "../components/Typography.astro";
import Button from "../components/Button.astro";
import LinkedinIcon from "../icons/LinkedinIcon.astro";
import GithubIcon from "../icons/GithubIcon.astro";
import EmailIcon from "../icons/EmailIcon.astro";
import { basics } from "@cv";
import { TITLE_PAGE_PREFIX } from "../utils/constants";
// Modern avatar design - no image needed
const { name, label, lastName } = basics;
---

<Layout
  title={`${TITLE_PAGE_PREFIX} Homepage`}
  description="Welcome to David Gimeno's portfolio. Software Engineer based in Barcelona, currently working at NTT Data as a Frontend Developer."
  type="profile"
  hideFooter={true}
>
  <HomeContainer>
    <div id="home" class="w-full h-full flex items-center">
      <div class="flex flex-col items-center justify-center w-full">
        <!-- Clean centered content -->
        <div
          class="flex flex-col space-y-4 sm:space-y-6 lg:space-y-8 text-center max-w-4xl"
        >
          <Typography
            as="h1"
            variant="h1"
            weight="bold"
            align="center"
            className="leading-tight mb-3"
          >
            Hello, I'm <span
              class="bg-gradient-to-r from-primary-600 to-secondary-500 dark:from-primary-400 dark:to-secondary-400 bg-clip-text text-transparent font-bold"
              >{name} {lastName}</span
            >
          </Typography>
          <Typography
            as="h2"
            variant="h2"
            color="secondary"
            weight="medium"
            align="center"
            className="leading-relaxed max-w-3xl mx-auto"
          >
            {label}
          </Typography>
          <div class="flex flex-wrap justify-center gap-4 sm:gap-6 pt-6">
            {
              basics.profiles.map((profile: any) => {
                const getProfileIconFromName = (networkName: string): any => {
                  switch (networkName) {
                    case "Linkedin":
                      return <LinkedinIcon />;
                    case "Github":
                      return <GithubIcon />;
                    case "Email":
                      return <EmailIcon />;
                  }
                };
                return (
                  <Button
                    variant="outline"
                    size="lg"
                    href={profile.url}
                    target="_blank"
                    rel="noopener"
                    className="backdrop-blur-sm"
                  >
                    {getProfileIconFromName(profile.network)}
                    <span class="ml-2">{profile.network}</span>
                  </Button>
                );
              })
            }
          </div>
        </div>
      </div>
    </div>
  </HomeContainer>
</Layout>
