---
import Layout from "../layouts/Layout.astro";
import { basics } from "@cv";
import { TITLE_PAGE_PREFIX } from "../utils/constants";
const { name, lastName, label, email } = basics;
---

<Layout
  title={`${TITLE_PAGE_PREFIX}Home`}
  description="Personal portfolio of David Gimeno — Software Engineer based in Barcelona."
  type="profile"
  hideFooter={true}
>
  <section class="min-h-screen flex flex-col items-center justify-center px-6">
    <div class="max-w-3xl w-full space-y-8 text-center reveal">
      <h1
        class="text-6xl sm:text-7xl lg:text-8xl font-bold tracking-tight text-text-primary uppercase leading-none"
      >
        {name}<br />{lastName}
      </h1>
      <p
        class="text-base sm:text-lg text-text-secondary max-w-xl mx-auto leading-relaxed"
      >
        {label}
      </p>
      <div class="pt-4">
        <a
          href={`mailto:${email}`}
          class="inline-block text-sm uppercase tracking-widest text-text-muted hover:text-text-primary border-b border-text-muted hover:border-text-primary pb-1 transition-colors duration-200"
        >
          Get in touch
        </a>
      </div>
    </div>
  </section>
</Layout>
