---
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
import { SITE_BASE } from "../utils/url";
import { t } from "../utils/i18n";
import { basics } from "@cv";
const { name, lastName, label, email } = basics;
---

<Layout
  title={`${name} ${lastName} — ${label}`}
  type="profile"
  hideFooter={true}
>
  <section class="flex min-h-screen flex-col items-center justify-center px-6">
    <div class="reveal w-full max-w-4xl">
      <!-- Greeting -->
      <p
        class="mb-4 text-xs uppercase tracking-widest text-text-muted"
        data-i18n="ui.home.greeting"
      >
        {t("ui.home.greeting")}
      </p>

      <!-- Name -->
      <h1
        class="mb-4 text-5xl font-bold uppercase leading-none tracking-tight text-text-primary sm:text-7xl lg:text-8xl"
      >
        <span class="block">{name}</span>
        <span class="block font-light">{lastName}</span>
      </h1>

      <!-- Rotating descriptor -->
      <p
        class="mb-10 flex min-h-[1.5em] text-2xl font-light uppercase tracking-widest text-text-secondary max-sm:whitespace-normal max-sm:text-xl sm:items-center sm:overflow-hidden sm:whitespace-nowrap sm:text-3xl"
        aria-live="polite"
        aria-atomic="true"
      >
        <span id="tw-rotating">{label}</span>
        <span class="typewriter-cursor" aria-hidden="true"></span>
      </p>

      <!-- CTAs -->
      <div
        class="flex flex-col items-start gap-5 sm:flex-row sm:items-center sm:gap-8"
      >
        <Button
          href={`${SITE_BASE}/projects`}
          variant="simple"
          size="none"
          className="gap-2 rounded-none border-b border-border-secondary pb-1 text-sm uppercase tracking-widest transition-colors duration-200 hover:border-text-primary hover:no-underline"
        >
          <svg
            class="h-4 w-4 shrink-0"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"
            ></path>
          </svg>
          <span data-i18n="ui.home.cta.work">{t("ui.home.cta.work")}</span>
        </Button>
        <Button
          href={`mailto:${email}`}
          variant="simple"
          size="none"
          className="gap-2 rounded-none border-b border-border-muted pb-1 text-sm uppercase tracking-widest text-text-muted transition-colors duration-200 hover:border-text-primary hover:text-text-primary hover:no-underline"
        >
          <svg
            class="h-4 w-4 shrink-0"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
          <span data-i18n="ui.home.cta">{t("ui.home.cta")}</span>
        </Button>
      </div>
    </div>
  </section>
</Layout>

<style>
  .typewriter-cursor {
    display: inline-block;
    width: 0.1em;
    height: 0.82em;
    background-color: currentColor;
    vertical-align: text-bottom;
    margin-left: 0.1em;
    border-radius: 1px;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .typewriter-cursor {
      display: none;
    }
  }
</style>

<script>
  import { getTypewriterPhrases } from "../utils/typewriter";
  import { getStoredLang } from "../utils/i18n-client";
  import type { LangCode } from "../utils/i18n";

  let stopCurrent: (() => void) | null = null;

  async function startTypewriter(lang: LangCode) {
    const el = document.getElementById("tw-rotating");
    const cursor = document.querySelector<HTMLElement>(".typewriter-cursor");
    if (!el || !cursor) return;

    stopCurrent?.();
    let stopped = false;
    stopCurrent = () => {
      stopped = true;
    };

    const phrases = await getTypewriterPhrases(lang);

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      el.textContent = phrases[0];
      cursor.style.display = "none";
      return;
    }

    cursor.style.display = "";
    let charIdx = 0;
    let phraseIdx = 0;
    let isDeleting = false;

    function rotate() {
      if (stopped) return;
      const current = phrases[phraseIdx];

      if (isDeleting) {
        charIdx--;
        el!.textContent = current.slice(0, charIdx);
        if (charIdx === 0) {
          isDeleting = false;
          phraseIdx = (phraseIdx + 1) % phrases.length;
          setTimeout(rotate, 350);
        } else {
          setTimeout(rotate, 35 + Math.random() * 20);
        }
      } else {
        charIdx++;
        el!.textContent = current.slice(0, charIdx);
        if (charIdx === current.length) {
          setTimeout(() => {
            if (stopped) return;
            isDeleting = true;
            rotate();
          }, 3500);
        } else {
          setTimeout(rotate, 80 + Math.random() * 40);
        }
      }
    }

    setTimeout(rotate, 600);
  }

  document.addEventListener("astro:page-load", () => {
    startTypewriter(getStoredLang());
  });

  window.addEventListener("app:lang-change", (e: Event) => {
    const { lang } = (e as CustomEvent<{ lang: LangCode }>).detail;
    startTypewriter(lang);
  });
</script>
