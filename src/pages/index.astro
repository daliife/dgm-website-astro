---
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
import { SITE_BASE } from "../utils/url";
import { basics } from "@cv";
const { name, lastName, label, email, summary } = basics;
---

<Layout
  title={`${name} ${lastName} — ${label}`}
  type="profile"
  hideFooter={true}
>
  <section class="min-h-screen flex flex-col items-center justify-center px-6">
    <div class="max-w-4xl w-full reveal">
      <!-- Greeting -->
      <p
        class="text-xs uppercase tracking-widest text-text-muted mb-4"
        data-i18n="ui.home.greeting"
      >
        Hello there, it's
      </p>

      <!-- Name -->
      <h1
        class="text-5xl sm:text-7xl lg:text-8xl font-bold tracking-tight text-text-primary uppercase leading-none mb-4"
      >
        <span class="block">{name}</span>
        <span class="block font-light">{lastName}</span>
      </h1>

      <!-- Rotating descriptor -->
      <p
        class="text-2xl sm:text-3xl font-light text-text-secondary uppercase tracking-widest mb-10 overflow-hidden whitespace-nowrap min-h-[1.5em] flex items-center"
        aria-live="polite"
      >
        <span id="tw-rotating" aria-hidden="true">{label}</span>
        <span class="typewriter-cursor" aria-hidden="true"></span>
      </p>

      <!-- SEO: visually hidden summary for crawlers -->
      <p class="sr-only">{summary}</p>

      <!-- CTAs -->
      <div
        class="flex flex-col sm:flex-row items-start sm:items-center gap-5 sm:gap-8"
      >
        <Button
          href={`${SITE_BASE}/projects`}
          variant="simple"
          size="none"
          className="text-sm uppercase tracking-widest border-b border-border-secondary hover:border-text-primary pb-1 hover:no-underline gap-2 rounded-none"
        >
          <svg
            class="w-4 h-4 shrink-0"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"
            ></path>
          </svg>
          <span data-i18n="ui.home.cta.work">Explore my projects</span>
        </Button>
        <Button
          href={`mailto:${email}`}
          variant="simple"
          size="none"
          className="text-sm uppercase tracking-widest text-text-muted border-b border-border-muted hover:text-text-primary hover:border-text-primary pb-1 hover:no-underline gap-2 rounded-none"
        >
          <svg
            class="w-4 h-4 shrink-0"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
          <span data-i18n="ui.home.cta">Get in touch</span>
        </Button>
      </div>
    </div>
  </section>
</Layout>

<style>
  .typewriter-cursor {
    display: inline-block;
    width: 0.1em;
    height: 0.82em;
    background-color: currentColor;
    vertical-align: text-bottom;
    margin-left: 0.1em;
    border-radius: 1px;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .typewriter-cursor {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const el = document.getElementById("tw-rotating");
    const cursor = document.querySelector<HTMLElement>(".typewriter-cursor");
    if (!el || !cursor) return;

    const lang = localStorage.getItem("lang") ?? "en";
    const phrases =
      lang === "ca"
        ? [
            "DESENVOLUPADOR FRONTEND",
            "ENGINYER DE SOFTWARE",
            "ESPECIALISTA EN REACT",
            "CLARINETISTA",
            "AMANT DE LA MUNTANYA",
          ]
        : lang === "es"
          ? [
              "DESARROLLADOR FRONTEND",
              "INGENIERO DE SOFTWARE",
              "ESPECIALISTA EN REACT",
              "CLARINETISTA",
              "AMANTE DE LA MONTAÑA",
            ]
          : [
              "FRONTEND DEVELOPER",
              "SOFTWARE ENGINEER",
              "REACT SPECIALIST",
              "CLARINETIST",
              "RUNNER & HIKING LOVER",
            ];

    // prefers-reduced-motion: show first phrase statically
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      el.textContent = phrases[0];
      cursor.style.display = "none";
      return;
    }

    let charIdx = 0;
    let phraseIdx = 0;
    let isDeleting = false;

    function rotate() {
      const current = phrases[phraseIdx];

      if (isDeleting) {
        charIdx--;
        el!.textContent = current.slice(0, charIdx);
        if (charIdx === 0) {
          isDeleting = false;
          phraseIdx = (phraseIdx + 1) % phrases.length;
          setTimeout(rotate, 350);
        } else {
          setTimeout(rotate, 35 + Math.random() * 20);
        }
      } else {
        charIdx++;
        el!.textContent = current.slice(0, charIdx);
        if (charIdx === current.length) {
          setTimeout(() => {
            isDeleting = true;
            rotate();
          }, 3500);
        } else {
          setTimeout(rotate, 80 + Math.random() * 40);
        }
      }
    }

    setTimeout(rotate, 600);
  });
</script>
