---
import Layout from "../layouts/Layout.astro";
import HomeContainer from "../components/HomeContainer.astro";
import Typography from "../components/Typography.astro";
import Button from "../components/Button.astro";
import LinkedinIcon from "../icons/LinkedinIcon.astro";
import GithubIcon from "../icons/GithubIcon.astro";
import EmailIcon from "../icons/EmailIcon.astro";
import { basics } from "@cv";
import { TITLE_PAGE_PREFIX } from "../utils/constants";
const { name, label, lastName } = basics;
---

<Layout
  title={`${TITLE_PAGE_PREFIX} Homepage`}
  description="Welcome to David Gimeno's portfolio. Software Engineer based in Barcelona, currently working at NTT Data as a Frontend Developer."
  type="profile"
  hideFooter={true}
>
  <HomeContainer>
    <div
      id="home"
      class="w-full h-full flex flex-col items-center justify-center"
    >
      <div
        class="flex flex-col space-y-3 sm:space-y-5 lg:space-y-8 text-center max-w-4xl px-4 sm:px-6"
      >
        <Typography
          as="h1"
          variant="h1"
          weight="bold"
          align="center"
          className="leading-tight mb-2"
        >
          Hello, I'm <span
            class="bg-gradient-to-r from-primary-600 to-secondary-500 dark:from-primary-400 dark:to-secondary-400 bg-clip-text text-transparent font-bold"
            >{name} {lastName}</span
          >
        </Typography>
        <Typography
          as="h2"
          variant="h2"
          color="secondary"
          weight="medium"
          align="center"
          className="leading-relaxed max-w-3xl mx-auto"
        >
          {label}
        </Typography>
        <div
          class="flex flex-wrap justify-center gap-3 sm:gap-4 lg:gap-6 pt-4 sm:pt-6"
        >
          {
            basics.profiles.map((profile: any) => {
              const getProfileIconFromName = (networkName: string): any => {
                switch (networkName) {
                  case "Linkedin":
                    return <LinkedinIcon />;
                  case "Github":
                    return <GithubIcon />;
                  case "Email":
                    return <EmailIcon />;
                }
              };
              return (
                <Button
                  variant="outline"
                  size="md"
                  href={profile.url}
                  target="_blank"
                  rel="noopener"
                  className="backdrop-blur-sm sm:size-lg"
                >
                  {getProfileIconFromName(profile.network)}
                  <span class="text-sm sm:text-base">{profile.network}</span>
                </Button>
              );
            })
          }
          <Button
            variant="primary"
            size="md"
            href="/cv-david-gimeno.jpeg"
            download="David-Gimeno-CV.pdf"
            className="backdrop-blur-sm bg-gradient-to-r from-primary-500/20 to-secondary-500/20 border-primary-400/40 hover:border-primary-400/60 hover:from-primary-500/30 hover:to-secondary-500/30 shadow-lg hover:shadow-xl hover:shadow-primary-500/20 ring-1 ring-primary-500/20 hover:ring-primary-500/30 sm:size-lg"
          >
            <svg
              class="w-4 h-4 sm:w-5 sm:h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path>
            </svg>
            <span class="text-sm sm:text-base">Download CV</span>
          </Button>
        </div>
      </div>
    </div>
  </HomeContainer>
</Layout>
