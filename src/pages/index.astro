---
import Layout from "../layouts/Layout.astro";
import HomeContainer from "../components/HomeContainer.astro";
import LinkedinIcon from "../icons/LinkedinIcon.astro";
import GithubIcon from "../icons/GithubIcon.astro";
import EmailIcon from "../icons/EmailIcon.astro";
import { basics } from "@cv";
import { TITLE_PAGE_PREFIX } from "../utils/constants";
// Modern avatar design - no image needed
const { name, label, lastName } = basics;
---

<Layout
  title={`${TITLE_PAGE_PREFIX} Homepage`}
  description="Welcome to David Gimeno's portfolio. Software Engineer based in Barcelona, currently working at NTT Data as a Frontend Developer."
  type="profile"
  hideFooter={true}
>
  <HomeContainer>
    <div id="home" class="w-full h-full flex items-center">
      <div class="flex flex-col items-center justify-center w-full">
        <!-- Clean centered content -->
        <div
          class="flex flex-col space-y-4 sm:space-y-6 lg:space-y-8 text-center max-w-4xl"
        >
          <h1
            class="font-bold text-3xl sm:text-4xl lg:text-5xl xl:text-6xl text-text-primary-light dark:text-text-primary-dark leading-tight"
          >
            Hello, I'm <span class="text-deep-blue-600 dark:text-deep-blue-400"
              >{name} {lastName}</span
            >
          </h1>
          <h2
            class="text-lg sm:text-xl lg:text-2xl xl:text-3xl text-text-secondary-light dark:text-text-secondary-dark leading-relaxed font-medium"
          >
            {label}
          </h2>
          <div class="flex flex-wrap justify-center gap-4 sm:gap-6 pt-6">
            {
              basics.profiles.map((profile: any) => {
                const getProfileIconFromName = (networkName: string): any => {
                  switch (networkName) {
                    case "Linkedin":
                      return <LinkedinIcon />;
                    case "Github":
                      return <GithubIcon />;
                    case "Email":
                      return <EmailIcon />;
                  }
                };
                return (
                  <a
                    href={profile.url}
                    rel="noopener"
                    target="_blank"
                    class="inline-flex items-center px-5 py-3 text-base font-medium text-text-primary-light dark:text-text-primary-dark hover:text-deep-blue-600 dark:hover:text-deep-blue-400 transition-colors duration-200 rounded-lg bg-bg-light/90 dark:bg-bg-dark-alt/80 hover:bg-deep-blue-50 dark:hover:bg-deep-blue-900/20 backdrop-blur-sm border border-deep-blue-200/60 dark:border-border-dark hover:border-deep-blue-300 dark:hover:border-deep-blue-600"
                  >
                    {getProfileIconFromName(profile.network)}
                    <span class="ml-2">{profile.network}</span>
                  </a>
                );
              })
            }
          </div>
        </div>
      </div>
    </div>
  </HomeContainer>
</Layout>
