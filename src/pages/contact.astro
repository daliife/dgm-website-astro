---
import Layout from "../layouts/Layout.astro";
import { basics } from "@cv";
import {
  TITLE_PAGE_SUFFIX,
  PAGE_CONTAINER_CLASSES,
  PAGE_HEADING_CLASSES,
  PAGE_HEADING_MARGIN_COMPACT_CLASSES,
} from "../utils/constants";
import { ICON_PATHS } from "../utils/icons";
import type { I18nKey } from "../i18n/en";
import type { SocialNetwork, SocialProfile } from "../types/ui";
import Button from "../components/ui/Button.astro";
import { t } from "../utils/i18n";
const { email, profiles } = basics;

const CONTACT_ICONS: Record<string, string> = {
  Email: ICON_PATHS.email,
  Github: ICON_PATHS.github,
  Linkedin: ICON_PATHS.linkedin,
};

const NETWORK_I18N: Record<SocialNetwork, I18nKey> = {
  Email: "ui.contact.network.email",
  Linkedin: "ui.contact.network.linkedin",
  Github: "ui.contact.network.github",
};

const CONTACT_ITEM_CLASS =
  "!flex flex-col !items-start !justify-start gap-1 rounded-none hover:no-underline w-full border-t border-border-primary pt-6 group";
---

<Layout
  title={`Contact${TITLE_PAGE_SUFFIX}`}
  description="Contact David Gimeno Mañé — Frontend Developer based in Barcelona. Let’s work together."
>
  <div class={PAGE_CONTAINER_CLASSES}>
    <h1
      class={`${PAGE_HEADING_CLASSES} ${PAGE_HEADING_MARGIN_COMPACT_CLASSES}`}
      data-i18n="ui.page.contact"
    >
      {t("ui.page.contact")}
    </h1>
    <p
      class="reveal mb-16 max-w-xl text-base leading-relaxed text-text-secondary sm:text-lg"
      data-i18n="ui.contact.intro"
    >
      {t("ui.contact.intro")}
    </p>
    <div class="reveal space-y-6">
      <Button
        href={`mailto:${email}`}
        variant="simple"
        size="none"
        className={CONTACT_ITEM_CLASS}
      >
        <span
          class="mb-2 flex items-center gap-1.5 text-xs uppercase tracking-widest text-text-muted"
        >
          <svg
            class="h-3.5 w-3.5 shrink-0"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <Fragment set:html={CONTACT_ICONS.Email} />
          </svg>
          <span data-i18n="ui.contact.network.email">
            {t("ui.contact.network.email")}
          </span>
        </span>
        <span class="contact-value text-lg text-text-primary sm:text-xl">
          {email}
        </span>
      </Button>
      {
        (profiles as SocialProfile[]).map((profile) => {
          if (profile.network === "Email") return null;
          const icon = CONTACT_ICONS[profile.network];
          const labelKey = NETWORK_I18N[profile.network];
          return (
            <Button
              href={profile.url}
              target="_blank"
              rel="noopener noreferrer"
              variant="simple"
              size="none"
              className={CONTACT_ITEM_CLASS}
            >
              <span class="mb-2 flex items-center gap-1.5 text-xs uppercase tracking-widest text-text-muted">
                {icon && (
                  <svg
                    class="h-3.5 w-3.5 shrink-0"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <Fragment set:html={icon} />
                  </svg>
                )}
                <span data-i18n={labelKey}>{t(labelKey)}</span>
              </span>
              <span class="contact-value text-lg text-text-primary sm:text-xl">
                {profile.username || profile.network}
              </span>
              <span class="sr-only" data-i18n="ui.a11y.opensNewTab">
                {t("ui.a11y.opensNewTab")}
              </span>
            </Button>
          );
        })
      }
    </div>
  </div>
</Layout>

<style>
  @media (hover: hover) {
    .contact-value {
      background-image: linear-gradient(currentColor, currentColor);
      background-size: 0% 1px;
      background-repeat: no-repeat;
      background-position: left bottom;
      transition: background-size 0.25s ease;
      padding-bottom: 1px;
    }
    :global(.group):hover .contact-value {
      background-size: 100% 1px;
    }
  }
</style>
