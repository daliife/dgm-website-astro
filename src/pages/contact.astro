---
import Layout from "../layouts/Layout.astro";
import { basics } from "@cv";
import {
  TITLE_PAGE_PREFIX,
  PAGE_CONTAINER_CLASSES,
  PAGE_HEADING_CLASSES,
} from "../utils/constants";
import type { SocialProfile } from "../types/ui";
import Button from "../components/ui/Button.astro";
const { email, profiles } = basics;
---

<Layout
  title={`${TITLE_PAGE_PREFIX}Contact`}
  description="Contact David Gimeno Mañé — Frontend Developer based in Barcelona. Let’s work together."
>
  <div class={PAGE_CONTAINER_CLASSES}>
    <h1 class={`${PAGE_HEADING_CLASSES} mb-6`} data-i18n="ui.page.contact">
      Contact
    </h1>
    <p
      class="text-text-secondary text-base sm:text-lg leading-relaxed max-w-xl mb-16 reveal"
      data-i18n="ui.contact.intro"
    >
      Interested in working together? Feel free to reach out through any of the
      channels below.
    </p>
    <div class="space-y-6 reveal">
      <Button
        href={`mailto:${email}`}
        variant="simple"
        size="none"
        className="!flex flex-col !items-start !justify-start gap-1 rounded-none hover:no-underline w-full border-t border-border-primary pt-6 group"
      >
        <span
          class="text-xs uppercase tracking-widest text-text-muted mb-2 block"
          >Email</span
        >
        <span
          class="text-lg sm:text-xl text-text-primary group-hover:opacity-60 transition-opacity duration-200"
        >
          {email}
        </span>
      </Button>
      {
        (profiles as SocialProfile[]).map(profile => {
          if (profile.network === "Email") return null;
          return (
            <Button
              href={profile.url}
              target="_blank"
              rel="noopener noreferrer"
              variant="simple"
              size="none"
              className="!flex flex-col !items-start !justify-start gap-1 rounded-none hover:no-underline w-full border-t border-border-primary pt-6 group"
            >
              <span class="text-xs uppercase tracking-widest text-text-muted mb-2 block">
                {profile.network}
              </span>
              <span class="text-lg sm:text-xl text-text-primary group-hover:opacity-60 transition-opacity duration-200">
                {profile.username || profile.network}
              </span>
            </Button>
          );
        })
      }
    </div>
  </div>
</Layout>
