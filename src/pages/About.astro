---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import PageContainer from "../components/PageContainer.astro";
import { basics } from "@cv";
import { TITLE_PAGE_PREFIX } from "../utils/constants";
const { summary } = basics;
---

<Layout
  title={`${TITLE_PAGE_PREFIX} About`}
  description="Learn more about David Gimeno's background, experience, and professional journey as a Software Engineer."
>
  <PageContainer type="narrow">
    <Section id="about" title="About me">
      <div class="prose prose-slate dark:prose-invert max-w-none">
        <p
          class="text-sm sm:text-base lg:text-lg text-text-secondary-light dark:text-text-secondary-dark text-pretty leading-relaxed"
        >
          {summary}
        </p>
      </div>
    </Section>
  </PageContainer>
</Layout>
