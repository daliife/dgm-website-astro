---
import Layout from "../layouts/Layout.astro";
import PageContainer from "../components/PageContainer.astro";
import { skills, languages } from "@cv";
import { TITLE_PAGE_PREFIX } from "../utils/constants";
---

<Layout
  title={`${TITLE_PAGE_PREFIX} About`}
  description="Learn more about David Gimeno's background, experience, and professional journey as a Software Engineer."
>
  <PageContainer type="narrow">
    <!-- Simplified Symmetric Layout -->
    <div class="min-h-screen py-8">
      <!-- Simplified Symmetric Grid -->
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto"
      >
        <!-- Main Hero + Journey Card - Centered -->
        <div
          class="md:col-span-2 lg:col-span-3 bg-gradient-to-br from-primary-500/10 to-secondary-500/10 rounded-xl p-6 border border-primary-500/20 backdrop-blur-sm text-center relative"
        >
          <!-- CV Download Button - Top Right Corner -->
          <a
            href="/cv-david-gimeno.pdf"
            download="David-Gimeno-CV.pdf"
            class="absolute top-4 right-4 inline-flex items-center px-4 py-2 bg-primary-500/20 hover:bg-primary-500/30 text-text-primary font-medium rounded-lg transition-all duration-300 backdrop-blur-sm border border-primary-500/30 hover:border-primary-500/50 hover:scale-105"
          >
            <svg
              class="w-4 h-4 mr-2"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
              ></path>
            </svg>
            Download CV
          </a>

          <!-- Profile Image -->
          <div
            class="w-32 h-32 mx-auto mb-8 rounded-full overflow-hidden border-4 border-white/30"
          >
            <img
              src="/david-profile.webp"
              alt="David Gimeno Mañé"
              class="w-full h-full object-cover"
            />
          </div>

          <!-- Name -->
          <h1 class="text-text-primary text-4xl font-bold mb-8">
            David Gimeno Mañé
          </h1>

          <!-- Story -->
          <p
            class="text-text-secondary text-lg leading-relaxed max-w-4xl mx-auto"
          >
            I'm a frontend web developer passionate about creating user-friendly
            and visually engaging interfaces. With experience in multimedia
            programming, 3D modeling, and Unity game development, I bring a
            diverse skill set to every project.
            <br /><br />
            I'm committed to continuous learning and staying up-to-date with the
            latest technologies to deliver innovative solutions.
          </p>
        </div>

        <!-- Experience Card -->
        <div
          class="bg-gradient-to-br from-primary-500/10 to-secondary-500/10 rounded-xl p-6 border border-primary-500/20 backdrop-blur-sm"
        >
          <div class="flex items-center mb-4">
            <div
              class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-500 to-secondary-500 flex items-center justify-center mr-3"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-text-primary font-semibold text-lg">Experience</h3>
          </div>
          <p class="text-text-secondary text-sm leading-relaxed mb-3">
            4+ years building web applications and interactive experiences
          </p>
          <div class="space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-text-primary font-medium">Web Development</span>
              <span class="text-text-secondary">4 years</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-text-primary font-medium">3D Modeling</span>
              <span class="text-text-secondary">3 years</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-text-primary font-medium">Game Development</span
              >
              <span class="text-text-secondary">2 years</span>
            </div>
          </div>
        </div>

        <!-- Education Card -->
        <div
          class="bg-gradient-to-br from-secondary-500/10 to-primary-500/10 rounded-xl p-6 border border-secondary-500/20 backdrop-blur-sm"
        >
          <div class="flex items-center mb-4">
            <div
              class="w-10 h-10 rounded-full bg-gradient-to-br from-secondary-500 to-primary-500 flex items-center justify-center mr-3"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 14l9-5-9-5-9 5 9 5z"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
                ></path>
              </svg>
            </div>
            <h3 class="text-text-primary font-semibold text-lg">Education</h3>
          </div>
          <div class="space-y-3">
            <div>
              <h4 class="text-text-primary font-medium text-sm">
                Master in Video Games
              </h4>
              <p class="text-text-secondary text-xs">Master's Degree</p>
            </div>
            <div>
              <h4 class="text-text-primary font-medium text-sm">
                Multimedia Engineering
              </h4>
              <p class="text-text-secondary text-xs">Bachelor's Degree</p>
            </div>
            <div>
              <h4 class="text-text-primary font-medium text-sm">
                Sound Technician
              </h4>
              <p class="text-text-secondary text-xs">Higher Education</p>
            </div>
          </div>
        </div>

        <!-- Skills Card -->
        <div
          class="bg-gradient-to-br from-primary-500/10 to-secondary-500/10 rounded-xl p-6 border border-primary-500/20 backdrop-blur-sm"
        >
          <div class="flex items-center mb-4">
            <div
              class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-500 to-secondary-500 flex items-center justify-center mr-3"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
            </div>
            <h3 class="text-text-primary font-semibold text-lg">Skills</h3>
          </div>
          <div class="space-y-3">
            {
              skills.slice(0, 3).map(skill => (
                <div>
                  <div class="flex justify-between text-sm mb-1">
                    <span class="text-text-primary font-medium">
                      {skill.name}
                    </span>
                    <span class="text-text-secondary">{skill.level}</span>
                  </div>
                  <div class="w-full bg-bg-muted/50 rounded-full h-2">
                    <div
                      class="bg-gradient-to-r from-primary-500 to-secondary-500 h-2 rounded-full transition-all duration-1000"
                      style={`width: ${skill.level === "Master" ? "100%" : skill.level === "Expert" ? "90%" : skill.level === "Advanced" ? "75%" : skill.level === "Intermediate" ? "60%" : "40%"}`}
                    />
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Languages Card -->
        <div
          class="bg-gradient-to-br from-secondary-500/10 to-primary-500/10 rounded-xl p-6 border border-secondary-500/20 backdrop-blur-sm"
        >
          <div class="flex items-center mb-4">
            <div
              class="w-10 h-10 rounded-full bg-gradient-to-br from-secondary-500 to-primary-500 flex items-center justify-center mr-3"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"
                ></path>
              </svg>
            </div>
            <h3 class="text-text-primary font-semibold text-lg">Languages</h3>
          </div>
          <div class="space-y-3">
            {
              languages.map(lang => (
                <div class="flex items-center justify-between">
                  <span class="text-text-primary font-medium text-sm">
                    {lang.language}
                  </span>
                  <span class="text-text-secondary text-xs">
                    {lang.fluency === "Professional working proficiency"
                      ? "Professional"
                      : lang.fluency}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Contact Links Card -->
        <div
          class="bg-gradient-to-br from-primary-500/10 to-secondary-500/10 rounded-xl p-6 border border-primary-500/20 backdrop-blur-sm"
        >
          <div class="flex items-center mb-4">
            <div
              class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-500 to-secondary-500 flex items-center justify-center mr-3"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
                ></path>
              </svg>
            </div>
            <h3 class="text-text-primary font-semibold text-lg">Contact</h3>
          </div>
          <div class="space-y-3">
            <a
              href="mailto:davidgimeno1992@gmail.com"
              class="flex items-center text-text-secondary hover:text-text-primary transition-colors duration-200"
            >
              <svg
                class="w-4 h-4 mr-3 flex-shrink-0"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                ></path>
              </svg>
              davidgimeno1992@gmail.com
            </a>
            <a
              href="https://github.com/daliife"
              target="_blank"
              rel="noopener"
              class="flex items-center text-text-secondary hover:text-text-primary transition-colors duration-200"
            >
              <svg
                class="w-4 h-4 mr-3 flex-shrink-0"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
              github.com/daliife
            </a>
            <a
              href="https://www.linkedin.com/in/daliife/"
              target="_blank"
              rel="noopener"
              class="flex items-center text-text-secondary hover:text-text-primary transition-colors duration-200"
            >
              <svg
                class="w-4 h-4 mr-3 flex-shrink-0"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
              linkedin.com/in/daliife
            </a>
          </div>
        </div>

        <!-- Interests Card -->
        <div
          class="bg-gradient-to-br from-secondary-500/10 to-primary-500/10 rounded-xl p-6 border border-secondary-500/20 backdrop-blur-sm"
        >
          <div class="flex items-center mb-4">
            <div
              class="w-10 h-10 rounded-full bg-gradient-to-br from-secondary-500 to-primary-500 flex items-center justify-center mr-3"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                ></path>
              </svg>
            </div>
            <h3 class="text-text-primary font-semibold text-lg">Interests</h3>
          </div>
          <div class="space-y-2">
            <div class="flex items-center">
              <span class="text-text-primary font-medium text-sm"
                >3D Modeling</span
              >
            </div>
            <div class="flex items-center">
              <span class="text-text-primary font-medium text-sm"
                >Game Development</span
              >
            </div>
            <div class="flex items-center">
              <span class="text-text-primary font-medium text-sm"
                >UI/UX Design</span
              >
            </div>
            <div class="flex items-center">
              <span class="text-text-primary font-medium text-sm"
                >Interactive Media</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </PageContainer>
</Layout>
