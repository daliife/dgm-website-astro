---
import Layout from "../layouts/Layout.astro";
import { basics, skills, languages, education, certificates } from "@cv";
import { TITLE_PAGE_PREFIX } from "../utils/constants";
const { summary } = basics;
---

<Layout
  title={`${TITLE_PAGE_PREFIX}About`}
  description="About David Gimeno — Software Engineer based in Barcelona."
>
  <div class="max-w-5xl mx-auto px-6 pt-32 pb-20 space-y-20">
    <!-- About Me -->
    <section class="reveal">
      <h1
        class="text-4xl sm:text-5xl font-bold tracking-tight text-text-primary uppercase mb-10"
      >
        About Me
      </h1>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <div class="space-y-6">
          {
            summary
              .split("\n\n")
              .map((para: string) => (
                <p class="text-text-secondary text-base sm:text-lg leading-relaxed">
                  {para}
                </p>
              ))
          }
        </div>
        <div class="flex justify-center md:justify-end">
          <div class="w-64 h-80 bg-bg-muted rounded-lg overflow-hidden">
            <img
              src="/david-profile.webp"
              alt="Portrait of David Gimeno"
              class="w-full h-full object-cover"
              width="256"
              height="320"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section class="reveal">
      <h2
        class="text-3xl sm:text-4xl font-bold tracking-tight text-text-primary uppercase mb-10"
      >
        Skills
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          skills.map((skill: any) => (
            <div>
              <h3 class="text-sm uppercase tracking-widest text-text-muted mb-3">
                {skill.name}
              </h3>
              <p class="text-text-secondary text-sm mb-2">{skill.level}</p>
              <div class="flex flex-wrap gap-2">
                {skill.keywords.map((keyword: string) => (
                  <span class="text-xs text-text-secondary border border-border-primary rounded-full px-3 py-1">
                    {keyword}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Languages -->
    <section class="reveal">
      <h2
        class="text-3xl sm:text-4xl font-bold tracking-tight text-text-primary uppercase mb-10"
      >
        Languages
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {
          languages.map((lang: any) => (
            <div class="border-t border-border-primary pt-4">
              <h3 class="text-text-primary font-medium">{lang.language}</h3>
              <p class="text-text-muted text-sm mt-1">{lang.fluency}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Education -->
    <section class="reveal">
      <h2
        class="text-3xl sm:text-4xl font-bold tracking-tight text-text-primary uppercase mb-10"
      >
        Education
      </h2>
      <div class="space-y-6">
        {
          education.map((edu: any) => (
            <div class="border-t border-border-primary pt-4">
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
                <div>
                  <h3 class="text-text-primary font-medium">{edu.studyType}</h3>
                  <p class="text-text-secondary text-sm">{edu.area}</p>
                </div>
                <span class="text-xs uppercase tracking-widest text-text-muted whitespace-nowrap">
                  {new Date(edu.startDate).getFullYear()} &mdash;{" "}
                  {new Date(edu.endDate).getFullYear()}
                </span>
              </div>
              <a
                href={edu.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-text-muted text-sm hover:text-text-primary transition-colors duration-200"
              >
                {edu.institution}
              </a>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Certificates -->
    <section class="reveal">
      <h2
        class="text-3xl sm:text-4xl font-bold tracking-tight text-text-primary uppercase mb-10"
      >
        Certificates
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {
          certificates.map((cert: any) => (
            <div class="border-t border-border-primary pt-4">
              <h3 class="text-text-primary font-medium text-sm">{cert.name}</h3>
              <p class="text-text-muted text-sm mt-1">{cert.issuer}</p>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</Layout>
