---
import NotFoundIcon from "src/icons/NotFoundIcon.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="404: Page Not Found">
  <div class="flex flex-col items-center gap-5">
    <NotFoundIcon />
    <div class="flex flex-col gap-1 text-center">
      <h1
        class="text-2xl font-semibold text-text-primary-light dark:text-text-primary-dark"
      >
        404: PAGE NOT FOUND
      </h1>
      <p
        class="text-md italic text-text-secondary-light dark:text-text-secondary-dark"
      >
        You just hit a route that doesn't exist... the sadness.
      </p>
    </div>
  </div>
</Layout>
