---
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
import { SITE_BASE } from "../utils/url";
import { t } from "../utils/i18n";

const NOT_FOUND_NAV_LINK =
  "w-fit rounded-none border-b border-border-muted pb-1 text-sm uppercase tracking-widest text-text-muted hover:border-text-primary hover:text-text-primary hover:no-underline";

const NOT_FOUND_BACK_LINK =
  "w-fit rounded-none pb-1 text-xs uppercase tracking-widest text-text-muted/50 hover:text-text-muted hover:no-underline";
---

<Layout title="404 — Page Not Found" noIndex={true}>
  <section
    class="flex min-h-screen flex-col items-center justify-center px-6 text-center"
  >
    <h1
      class="mb-4 text-6xl font-bold tracking-tight text-text-primary sm:text-8xl"
    >
      404
    </h1>
    <p
      class="mb-10 text-base text-text-muted sm:text-lg"
      data-i18n="ui.404.message"
    >
      {t("ui.404.message")}
    </p>
    <nav
      aria-label={t("ui.404.nav.aria")}
      data-i18n-aria="ui.404.nav.aria"
      class="mb-10 flex flex-col items-center gap-5 sm:flex-row sm:gap-8"
    >
      <Button
        href={`${SITE_BASE}/work`}
        variant="simple"
        size="none"
        className={NOT_FOUND_NAV_LINK}
      >
        <span data-i18n="ui.nav.work">{t("ui.nav.work")}</span>
      </Button>
      <Button
        href={`${SITE_BASE}/projects`}
        variant="simple"
        size="none"
        className={NOT_FOUND_NAV_LINK}
      >
        <span data-i18n="ui.nav.projects">{t("ui.nav.projects")}</span>
      </Button>
      <Button
        href={`${SITE_BASE}/contact`}
        variant="simple"
        size="none"
        className={NOT_FOUND_NAV_LINK}
      >
        <span data-i18n="ui.nav.contact">{t("ui.nav.contact")}</span>
      </Button>
    </nav>
    <Button
      href={`${SITE_BASE}/`}
      variant="simple"
      size="none"
      className={NOT_FOUND_BACK_LINK}
    >
      <span data-i18n="ui.404.back">{t("ui.404.back")}</span>
    </Button>
  </section>
</Layout>
