---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Page Not Found">
  <section class="min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <h1 class="text-6xl sm:text-8xl font-bold tracking-tight text-text-primary mb-4">
      404
    </h1>
    <p class="text-text-muted text-base sm:text-lg mb-8">
      Page not found
    </p>
    <a
      href="/"
      class="text-sm uppercase tracking-widest text-text-muted hover:text-text-primary border-b border-text-muted hover:border-text-primary pb-1 transition-colors duration-200"
    >
      Back to home
    </a>
  </section>
</Layout>
