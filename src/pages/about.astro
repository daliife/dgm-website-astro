---
import Layout from "../layouts/Layout.astro";
import { basics, work, skills, languages, education, certificates } from "@cv";
import { TITLE_PAGE_PREFIX } from "../utils/constants";
import { formatDate } from "../utils/format";
import Button from "../components/ui/Button.astro";
import type {
  SocialProfile,
  WorkEntry,
  SkillEntry,
  LanguageEntry,
  EducationEntry,
  CertificateEntry,
} from "../types/ui";
const {
  name,
  lastName,
  email,
  summary,
  profiles,
  label,
  location,
  image: profileImage,
} = basics;

function stripProtocol(url: string): string {
  return url.replace(/^https?:\/\/(www\.)?/, "");
}

const linkedin = (profiles as SocialProfile[])?.find(
  p => p.network === "Linkedin"
);
const github = (profiles as SocialProfile[])?.find(p => p.network === "Github");
---

<Layout
  title={`${TITLE_PAGE_PREFIX}About`}
  description="About David Gimeno — Software Engineer based in Barcelona."
>
  <div
    class="max-w-5xl mx-auto px-6 pt-24 md:pt-32 pb-20 content-wrapper print:pt-0 print:pb-0 print:px-0 print:max-w-none"
  >
    <!-- Print-only CV header -->
    <div class="hidden print:flex print:items-start print:gap-4 print:mb-8">
      <img
        src={profileImage ?? "/david-profile.webp"}
        alt="Portrait of David Gimeno"
        class="print:w-16 print:h-[80px] print:object-cover print:rounded"
        width="56"
        height="70"
      />
      <div>
        <h1
          class="print:text-2xl print:font-bold print:uppercase print:text-black print:leading-tight"
        >
          {name}
          {lastName}
        </h1>
        <p class="print:text-xs print:text-gray-600 print:mt-1">
          {label}
        </p>
        <div
          class="print:flex print:flex-wrap print:gap-x-4 print:mt-1.5 print:text-[11px] print:text-gray-500"
        >
          <span>{email}</span>
          {
            location && (
              <span>
                {location.city}, {location.region}
              </span>
            )
          }
          {linkedin && <span>{stripProtocol(linkedin.url)}</span>}
          {github && <span>{stripProtocol(github.url)}</span>}
        </div>
      </div>
    </div>
    <!-- About Me -->
    <section class="reveal">
      <!-- Title row -->
      <div class="mb-10 print:mb-1">
        <h1
          class="text-4xl sm:text-5xl font-bold tracking-tight text-text-primary uppercase print:text-[10px] print:font-medium print:tracking-widest print:border-b print:border-gray-300 print:pb-0.5 print:w-full print:normal-case print:text-black"
        >
          <span class="print:hidden" data-i18n="ui.page.about">About</span>
          <span class="hidden print:inline" data-i18n="ui.about.summary"
            >Summary</span
          >
        </h1>
      </div>

      <!-- Content: image left, bio right -->
      <div
        class="grid grid-cols-1 md:grid-cols-[5fr_7fr] gap-10 md:gap-14 items-start print:block"
      >
        <!-- Image -->
        <div class="img-frame overflow-hidden bg-bg-muted print:hidden group">
          <img
            src={profileImage ?? "/david-profile.webp"}
            alt="Portrait of David Gimeno"
            class="w-full aspect-[4/5] object-cover [@media(hover:hover)]:grayscale [@media(hover:hover)]:group-hover:grayscale-0 [@media(hover:hover)]:group-hover:scale-[1.04] transition-all duration-300 ease-out"
            width="400"
            height="500"
            loading="eager"
          />
        </div>

        <!-- Bio text -->
        <div class="flex flex-col justify-start print:space-y-1">
          <p
            class="text-xs uppercase tracking-widest text-text-muted mb-1 print:hidden"
            data-i18n="basics.label"
          >
            {label}
          </p>
          {
            location && (
              <p
                class="text-xs uppercase tracking-widest text-text-muted mb-8 print:hidden"
                data-i18n="basics.location"
              >
                {location.city} &middot; {location.region}
              </p>
            )
          }
          <div class="space-y-5 print:space-y-1">
            {
              summary.split("\n\n").map((para: string, paraIndex: number) => (
                <p
                  class="text-text-secondary text-base leading-relaxed print:text-[10px] print:leading-snug print:text-gray-700"
                  data-i18n={`basics.summary.${paraIndex}`}
                >
                  {para}
                </p>
              ))
            }
          </div>
          <div class="mt-8 print:hidden">
            <Button id="print-cv" variant="outline" size="sm">
              <svg
                class="w-4 h-4 shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18.25 7.034V3.375"
                ></path>
              </svg>
              <span data-i18n="ui.about.printcv">Print CV</span>
            </Button>
          </div>
        </div>
      </div>
    </section>

    <!-- Work Experience (print only) -->
    <section class="hidden print:block">
      <h2
        class="print:text-[10px] print:uppercase print:tracking-widest print:font-medium print:border-b print:border-gray-300 print:pb-0.5 print:mb-1.5 print:text-black"
        data-i18n="ui.about.experience"
      >
        Experience
      </h2>
      {
        work.map((job: WorkEntry, jobIndex: number) => (
          <div class="print:mb-5 print:break-inside-avoid">
            <div class="print:flex print:items-baseline print:justify-between">
              <div>
                <span
                  class="print:text-[11px] print:font-semibold print:text-black"
                  data-i18n={`work.${jobIndex}.position`}
                >
                  {job.position}
                </span>
                <span class="print:text-[11px] print:text-gray-600">
                  {" "}
                  — {job.company}
                </span>
              </div>
              <span class="print:text-[10px] print:text-gray-500 print:whitespace-nowrap">
                {formatDate(job.startDate)} — {formatDate(job.endDate)}
              </span>
            </div>
            {job.summary && (
              <p
                class="print:text-[10px] print:text-gray-600 print:leading-relaxed print:mt-1.5"
                data-i18n={`work.${jobIndex}.summary`}
              >
                {job.summary}
              </p>
            )}
            {job.highlights && job.highlights.length > 0 && (
              <ul class="print:mt-1.5 print:space-y-1">
                {job.highlights.map((h: string, hIndex: number) => (
                  <li
                    class="print:text-[10px] print:text-gray-600 print:leading-snug print:pl-3 print:relative before:content-['–'] before:absolute before:left-0 before:text-gray-400"
                    data-i18n={`work.${jobIndex}.highlights.${hIndex}`}
                  >
                    {h}
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </section>

    <!-- Skills -->
    <section class="reveal mt-20 print:mt-6">
      <h2
        class="text-3xl sm:text-4xl font-bold tracking-tight text-text-primary uppercase mb-10 print:text-[10px] print:tracking-widest print:font-medium print:border-b print:border-gray-300 print:pb-0.5 print:mb-1.5 print:normal-case print:text-black"
        data-i18n="ui.about.skills"
      >
        Skills
      </h2>
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 print:block print:space-y-3"
      >
        {
          skills.map((skill: SkillEntry, skillIndex: number) => (
            <div class="print:flex print:items-baseline print:gap-x-2">
              <h3 class="text-sm uppercase tracking-widest text-text-muted mb-3 print:text-[10px] print:mb-0 print:font-medium print:text-gray-900 print:shrink-0">
                <span data-i18n={`skills.${skillIndex}.name`}>
                  {skill.name}
                </span>
                <span class="hidden print:inline">:</span>
              </h3>
              <p
                class="text-text-secondary text-sm mb-2 print:hidden"
                data-i18n={`skills.${skillIndex}.level`}
              >
                {skill.level}
              </p>
              <div class="flex flex-wrap gap-2 print:contents">
                {skill.keywords.map((keyword: string, i: number) => (
                  <span class="text-xs text-text-secondary border border-border-primary rounded-full px-3 py-1 print:border-0 print:p-0 print:text-[10px] print:text-gray-600 print:rounded-none print:inline">
                    {keyword}
                    {i < skill.keywords.length - 1 ? (
                      <span class="hidden print:inline">,&nbsp;</span>
                    ) : null}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Languages -->
    <section class="reveal mt-20 print:mt-6">
      <h2
        class="text-3xl sm:text-4xl font-bold tracking-tight text-text-primary uppercase mb-10 print:text-[10px] print:tracking-widest print:font-medium print:border-b print:border-gray-300 print:pb-0.5 print:mb-1.5 print:normal-case print:text-black"
        data-i18n="ui.about.languages"
      >
        Languages
      </h2>
      <div
        class="grid grid-cols-1 sm:grid-cols-3 gap-6 print:flex print:gap-x-6"
      >
        {
          languages.map((lang: LanguageEntry, langIndex: number) => (
            <div class="border-t border-border-primary pt-4 print:border-0 print:pt-0">
              <h3 class="text-text-primary font-medium print:text-[10px] print:text-gray-900">
                {lang.language}
              </h3>
              <p
                class="text-text-muted text-sm mt-1 print:text-[10px] print:mt-0 print:text-gray-500"
                data-i18n={`languages.${langIndex}.fluency`}
              >
                {lang.fluency}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Education -->
    <section class="reveal mt-20 print:mt-6">
      <h2
        class="text-3xl sm:text-4xl font-bold tracking-tight text-text-primary uppercase mb-10 print:text-[10px] print:tracking-widest print:font-medium print:border-b print:border-gray-300 print:pb-0.5 print:mb-1.5 print:normal-case print:text-black"
        data-i18n="ui.about.education"
      >
        Education
      </h2>
      <div class="space-y-6 print:space-y-4">
        {
          education.map((edu: EducationEntry, eduIndex: number) => (
            <div class="border-t border-border-primary pt-4 print:border-0 print:pt-0">
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 print:flex-row print:gap-0">
                <div>
                  <h3
                    class="text-text-primary font-medium print:text-[10px] print:font-semibold print:text-gray-900"
                    data-i18n={`education.${eduIndex}.studyType`}
                  >
                    {edu.studyType}
                  </h3>
                  <p class="text-text-secondary text-sm print:text-[10px] print:text-gray-600">
                    <span data-i18n={`education.${eduIndex}.area`}>
                      {edu.area}
                    </span>{" "}
                    <span class="hidden print:inline">— {edu.institution}</span>
                  </p>
                </div>
                <span class="text-xs uppercase tracking-widest text-text-muted whitespace-nowrap print:text-[9px] print:text-gray-500">
                  {new Date(edu.startDate).getFullYear()} &mdash;{" "}
                  {new Date(edu.endDate).getFullYear()}
                </span>
              </div>
              <a
                href={edu.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-text-secondary text-sm underline underline-offset-2 decoration-text-secondary/40 hover:text-text-primary hover:decoration-text-primary transition-all duration-200 print:hidden"
              >
                {edu.institution}
              </a>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Certificates -->
    <section class="reveal mt-20 print:mt-6">
      <h2
        class="text-3xl sm:text-4xl font-bold tracking-tight text-text-primary uppercase mb-10 print:text-[10px] print:tracking-widest print:font-medium print:border-b print:border-gray-300 print:pb-0.5 print:mb-1.5 print:normal-case print:text-black"
        data-i18n="ui.about.certificates"
      >
        Certificates
      </h2>
      <div
        class="grid grid-cols-1 sm:grid-cols-3 gap-6 print:flex print:gap-x-6"
      >
        {
          certificates.map((cert: CertificateEntry) => (
            <div class="border-t border-border-primary pt-4 print:border-0 print:pt-0">
              <h3 class="text-text-primary font-medium text-sm print:text-[10px] print:text-gray-900">
                {cert.name}
              </h3>
              <p class="text-text-muted text-sm mt-1 print:text-[10px] print:mt-0 print:text-gray-500">
                {cert.issuer}
              </p>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</Layout>

<style>
  @media print {
    @page {
      margin: 14mm 16mm;
      size: A4;
    }

    :global(body) {
      background: white !important;
      color: black !important;
      font-size: 12px !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    :global(header),
    :global(footer),
    :global(nav),
    :global(.astro-route-announcer) {
      display: none !important;
    }

    /* Main content container */
    .content-wrapper {
      max-width: none !important;
    }

    /* Reveal animations: reset so all sections are visible */
    .reveal {
      opacity: 1 !important;
      transform: none !important;
    }

    /* Allow sections to break across pages naturally */
    section {
      break-inside: auto;
      orphans: 3;
      widows: 3;
    }

    /* Headings should never be orphaned at bottom of page */
    h2,
    h3 {
      break-after: avoid-page;
    }

    /* Work entries: keep position + summary together */
    li,
    p {
      orphans: 2;
      widows: 2;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("print-cv");
    if (btn) {
      btn.addEventListener("click", () => {
        window.print();
      });
    }
  });
</script>
