---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import profileImgSrc from "../assets/images/david-profile.webp";
import { basics, work, skills, languages, education, certificates } from "@cv";
import { TITLE_PAGE_PREFIX, PAGE_CONTAINER_CLASSES } from "../utils/constants";
import { stripProtocol } from "../utils/format";
import { getSocialProfile } from "../utils/socialLinks";
import { SITE_BASE } from "../utils/url";
import { LIVE_URL } from "../utils/constants";
import Button from "../components/ui/Button.astro";
import SkillsSection from "../components/sections/SkillsSection.astro";
import LanguagesSection from "../components/sections/LanguagesSection.astro";
import EducationSection from "../components/sections/EducationSection.astro";
import CertificatesSection from "../components/sections/CertificatesSection.astro";
import PrintWorkSection from "../components/sections/PrintWorkSection.astro";
import type { SocialProfile, WorkEntry } from "../types/ui";
const { name, lastName, email, summary, profiles, label, location } = basics;

const linkedin = getSocialProfile(profiles as SocialProfile[], "Linkedin");
const github = getSocialProfile(profiles as SocialProfile[], "Github");

const profilePageSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  name: `About ${name} ${lastName}`,
  description: `About ${name} ${lastName} — ${label} based in ${location?.city}. Discover my story, skills, and professional background.`,
  url: `${LIVE_URL}/about`,
  mainEntity: {
    "@type": "Person",
    name: `${name} ${lastName}`,
    jobTitle: label,
    url: LIVE_URL,
  },
};
---

<Layout
  title={`About${TITLE_PAGE_PREFIX}`}
  description={`About ${name} ${lastName} — ${label} based in ${location?.city}. Discover my story, skills, and professional background.`}
>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(profilePageSchema)}
  />
  <div
    class={`${PAGE_CONTAINER_CLASSES} content-wrapper print:pt-0 print:pb-0 print:px-0 print:max-w-none`}
  >
    <!-- Print-only CV header -->
    <div class="hidden print:flex print:items-start print:gap-4 print:mb-8">
      <Image
        src={profileImgSrc}
        alt="Portrait of David Gimeno"
        class="print:w-16 print:h-[80px] print:object-cover print:rounded"
        width={56}
        height={70}
        loading="eager"
        format="webp"
        quality={85}
      />
      <div>
        <p
          class="print:text-2xl print:font-bold print:uppercase print:text-black print:leading-tight"
        >
          {name}
          {lastName}
        </p>
        <p class="print:text-xs print:text-gray-600 print:mt-1">
          {label}
        </p>
        <div
          class="print:flex print:flex-wrap print:gap-x-4 print:mt-1.5 print:text-[11px] print:text-gray-500"
        >
          <span>{email}</span>
          {
            location && (
              <span>
                {location.city}, {location.region}
              </span>
            )
          }
          {linkedin && <span>{stripProtocol(linkedin.url)}</span>}
          {github && <span>{stripProtocol(github.url)}</span>}
        </div>
      </div>
    </div>
    <!-- About Me -->
    <section class="reveal">
      <!-- Title row -->
      <div class="mb-10 print:mb-1">
        <h1
          class="text-4xl sm:text-5xl font-bold tracking-tight text-text-primary uppercase print:text-[10px] print:font-medium print:tracking-widest print:border-b print:border-gray-300 print:pb-0.5 print:w-full print:normal-case print:text-black"
        >
          <span class="print:hidden" data-i18n="ui.page.about">About</span>
          <span class="hidden print:inline" data-i18n="ui.about.summary"
            >Summary</span
          >
        </h1>
      </div>

      <!-- Content: image left, bio right -->
      <div
        class="grid grid-cols-1 md:grid-cols-[5fr_7fr] gap-10 md:gap-14 items-start print:block"
      >
        <!-- Image -->
        <div class="img-frame overflow-hidden bg-bg-muted print:hidden group">
          <Image
            src={profileImgSrc}
            alt="Portrait of David Gimeno"
            class="w-full aspect-[4/5] object-cover [@media(hover:hover)]:group-hover:grayscale [@media(hover:hover)]:group-hover:scale-[1.04] transition-all duration-300 ease-out"
            width={400}
            height={500}
            loading="eager"
            fetchpriority="high"
            format="avif"
            quality={80}
          />
        </div>

        <!-- Bio text -->
        <div class="flex flex-col justify-start print:space-y-1">
          <p
            class="text-xs uppercase tracking-widest text-text-muted mb-1 print:hidden"
            data-i18n="basics.label"
          >
            {label}
          </p>
          {
            location && (
              <p
                class="text-xs uppercase tracking-widest text-text-muted mb-8 print:hidden"
                data-i18n="basics.location"
              >
                {location.city} &middot; {location.region}
              </p>
            )
          }
          <div class="space-y-5 print:space-y-1">
            {
              summary.split("\n\n").map((para: string, paraIndex: number) => (
                <p
                  class="text-text-secondary text-base leading-relaxed print:text-[10px] print:leading-snug print:text-gray-700"
                  data-i18n={`basics.summary.${paraIndex}`}
                >
                  {para}
                </p>
              ))
            }
          </div>
          <div class="mt-8 print:hidden">
            <Button id="print-cv" variant="outline" size="sm">
              <svg
                class="w-4 h-4 shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18.25 7.034V3.375"
                ></path>
              </svg>
              <span data-i18n="ui.about.printcv">Print CV</span>
            </Button>
          </div>
        </div>
      </div>
    </section>

    <PrintWorkSection work={work as WorkEntry[]} />
    <SkillsSection skills={skills} />
    <LanguagesSection languages={languages} />
    <EducationSection education={education} />
    <CertificatesSection certificates={certificates} />

    <nav
      aria-label="Related pages"
      class="border-t border-border-primary pt-8 mt-12 print:hidden reveal"
    >
      <p
        class="text-xs uppercase tracking-widest text-text-muted mb-5"
        data-i18n="ui.nextup"
      >
        Also explore
      </p>
      <div class="flex flex-col sm:flex-row gap-5 sm:gap-8">
        <a
          href={`${SITE_BASE}/work`}
          class="text-sm uppercase tracking-widest text-text-primary border-b border-border-secondary hover:border-text-primary pb-1 transition-colors duration-200 w-fit"
          data-i18n="ui.nextup.work">My work experience</a
        >
        <a
          href={`${SITE_BASE}/projects`}
          class="text-sm uppercase tracking-widest text-text-primary border-b border-border-secondary hover:border-text-primary pb-1 transition-colors duration-200 w-fit"
          data-i18n="ui.nextup.projects">My projects</a
        >
      </div>
    </nav>
  </div>
</Layout>

<style is:global>
  @import "../styles/print.css";
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("print-cv");
    if (btn) {
      btn.addEventListener("click", () => {
        window.print();
      });
    }
  });
</script>
