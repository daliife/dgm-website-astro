---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import profileImgSrc from "../assets/images/david-profile.webp";
import { basics, work, skills, languages, education, certificates } from "@cv";
import {
  TITLE_PAGE_SUFFIX,
  PAGE_CONTAINER_CLASSES,
  PAGE_HEADING_CLASSES,
  PAGE_HEADING_MARGIN_CLASSES,
  LIVE_URL,
} from "../utils/constants";
import { stripProtocol } from "../utils/format";
import { getSocialProfile } from "../utils/socialLinks";
import { SITE_BASE } from "../utils/url";
import Button from "../components/ui/Button.astro";
import SkillsSection from "../components/sections/SkillsSection.astro";
import LanguagesSection from "../components/sections/LanguagesSection.astro";
import EducationSection from "../components/sections/EducationSection.astro";
import CertificatesSection from "../components/sections/CertificatesSection.astro";
import PrintWorkSection from "../components/sections/PrintWorkSection.astro";
import NextUpNav from "../components/layout/NextUpNav.astro";
import { NEXTUP_NAV_CLASSES } from "../utils/constants";
import type { SocialProfile, WorkEntry } from "../types/ui";
import type { I18nKey } from "../i18n/en";
import { t } from "../utils/i18n";
const { name, lastName, email, summary, profiles, label, location } = basics;

const linkedin = getSocialProfile(profiles as SocialProfile[], "Linkedin");
const github = getSocialProfile(profiles as SocialProfile[], "Github");

const profilePageSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  name: `About ${name} ${lastName}`,
  description: `About ${name} ${lastName} — ${label} based in ${location?.city}. Discover my story, skills, and professional background.`,
  url: `${LIVE_URL}/about`,
  mainEntity: {
    "@type": "Person",
    name: `${name} ${lastName}`,
    jobTitle: label,
    url: LIVE_URL,
  },
};
---

<Layout
  title={`About${TITLE_PAGE_SUFFIX}`}
  description={`About ${name} ${lastName} — ${label} based in ${location?.city}. Discover my story, skills, and professional background.`}
>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(profilePageSchema)}
  />
  <div
    class={`${PAGE_CONTAINER_CLASSES} content-wrapper print:pt-0 print:pb-0 print:px-0 print:max-w-none`}
  >
    <!-- Print-only CV header -->
    <div class="hidden print:mb-8 print:flex print:items-start print:gap-4">
      <Image
        src={profileImgSrc}
        alt="Portrait of David Gimeno"
        class="print:h-[80px] print:w-16 print:rounded print:object-cover"
        width={56}
        height={70}
        loading="eager"
        format="webp"
        quality={85}
      />
      <div>
        <p
          class="print:text-2xl print:font-bold print:uppercase print:leading-tight print:text-black"
        >
          {name}
          {lastName}
        </p>
        <p class="print:mt-1 print:text-xs print:text-gray-600">
          {label}
        </p>
        <div
          class="print:mt-1.5 print:flex print:flex-wrap print:gap-x-4 print:text-[11px] print:text-gray-500"
        >
          <span>{email}</span>
          {
            location && (
              <span>
                {location.city}, {location.region}
              </span>
            )
          }
          {linkedin && <span>{stripProtocol(linkedin.url)}</span>}
          {github && <span>{stripProtocol(github.url)}</span>}
        </div>
      </div>
    </div>
    <!-- About Me -->
    <section>
      <h1
        class={`${PAGE_HEADING_CLASSES} ${PAGE_HEADING_MARGIN_CLASSES} print:mb-1 print:w-full print:border-b print:border-gray-300 print:pb-0.5 print:text-[10px] print:font-medium print:normal-case print:tracking-widest print:text-black`}
      >
        <span class="print:hidden" data-i18n="ui.page.about"
          >{t("ui.page.about")}</span
        >
        <span class="hidden print:inline" data-i18n="ui.about.summary"
          >{t("ui.about.summary")}</span
        >
      </h1>

      <!-- Content: image left, bio right -->
      <div
        class="reveal grid grid-cols-1 items-start gap-10 md:grid-cols-[5fr_7fr] md:gap-14 print:block"
      >
        <!-- Image -->
        <div class="img-frame group overflow-hidden bg-bg-muted print:hidden">
          <Image
            src={profileImgSrc}
            alt="Portrait of David Gimeno"
            class="aspect-[4/5] w-full object-cover transition-all duration-300 ease-out [@media(hover:hover)]:group-hover:scale-[1.04] [@media(hover:hover)]:group-hover:grayscale"
            width={400}
            height={500}
            loading="eager"
            fetchpriority="high"
            format="avif"
            quality={80}
          />
        </div>

        <!-- Bio text -->
        <div class="flex flex-col justify-start print:space-y-1">
          <p
            class="mb-1 text-xs uppercase tracking-widest text-text-muted print:hidden"
            data-i18n="basics.label"
          >
            {t("basics.label")}
          </p>
          {
            location && (
              <p
                class="mb-8 text-xs uppercase tracking-widest text-text-muted print:hidden"
                data-i18n="basics.location"
              >
                {t("basics.location")}
              </p>
            )
          }
          <div class="space-y-5 print:space-y-1">
            {
              summary.split("\n\n").map((para: string, paraIndex: number) => (
                <p
                  class="text-base leading-relaxed text-text-secondary print:text-[10px] print:leading-snug print:text-gray-700"
                  data-i18n={`basics.summary.${paraIndex}`}
                >
                  {t(`basics.summary.${paraIndex}` as I18nKey, para)}
                </p>
              ))
            }
          </div>
          <div class="mt-8 print:hidden">
            <Button id="print-cv" variant="outline" size="sm">
              <svg
                class="h-4 w-4 shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18.25 7.034V3.375"
                ></path>
              </svg>
              <span data-i18n="ui.about.printcv">{t("ui.about.printcv")}</span>
            </Button>
          </div>
        </div>
      </div>
    </section>

    <PrintWorkSection work={work as WorkEntry[]} />
    <SkillsSection skills={skills} />
    <LanguagesSection languages={languages} />
    <EducationSection education={education} />
    <CertificatesSection certificates={certificates} />

    <NextUpNav
      className={`${NEXTUP_NAV_CLASSES} mt-12 print:hidden`}
      links={[
        { href: `${SITE_BASE}/work`, labelKey: "ui.nextup.work" },
        { href: `${SITE_BASE}/projects`, labelKey: "ui.nextup.projects" },
      ]}
    />
  </div>
</Layout>

<style is:global>
  @import "../styles/print.css";
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("print-cv");
    if (btn) {
      btn.addEventListener("click", () => {
        window.print();
      });
    }
  });
</script>
