---
import Layout from "../layouts/Layout.astro";
import { work } from "@cv";
import { TITLE_PAGE_PREFIX } from "../utils/constants";
import WorkCard from "../components/sections/WorkCard.astro";
import type { WorkEntry } from "../types/ui";
---

<Layout
  title={`${TITLE_PAGE_PREFIX}Work`}
  description="Professional work experience of David Gimeno."
>
  <div class="max-w-5xl mx-auto px-6 pt-24 md:pt-32 pb-20">
    <h1
      class="text-4xl sm:text-5xl font-bold tracking-tight text-text-primary uppercase mb-12 reveal"
      data-i18n="ui.page.work"
    >
      Work
    </h1>
    <div class="space-y-0 reveal">
      {work.map((job: WorkEntry, i: number) => <WorkCard {job} jobIndex={i} />)}
    </div>
  </div>
</Layout>
