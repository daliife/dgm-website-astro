---
import Layout from "../layouts/Layout.astro";
import { work } from "@cv";
import {
  TITLE_PAGE_PREFIX,
  PAGE_CONTAINER_CLASSES,
  PAGE_HEADING_CLASSES,
} from "../utils/constants";
import { SITE_BASE } from "../utils/url";
import WorkCard from "../components/sections/WorkCard.astro";
import type { WorkEntry } from "../types/ui";
---

<Layout
  title={`Work Experience${TITLE_PAGE_PREFIX}`}
  description="Professional work experience of David Gimeno Mañé — Frontend Developer based in Barcelona."
>
  <div class={PAGE_CONTAINER_CLASSES}>
    <h1 class={`${PAGE_HEADING_CLASSES} mb-12`} data-i18n="ui.page.work">
      Work
    </h1>
    <div class="space-y-0 reveal">
      {work.map((job: WorkEntry, i: number) => <WorkCard {job} jobIndex={i} />)}
    </div>

    <nav
      aria-label="Related pages"
      class="border-t border-border-primary pt-8 mt-4 reveal"
    >
      <p
        class="text-xs uppercase tracking-widest text-text-muted mb-5"
        data-i18n="ui.nextup"
      >
        Also explore
      </p>
      <div class="flex flex-col sm:flex-row gap-5 sm:gap-8">
        <a
          href={`${SITE_BASE}/projects`}
          class="text-sm uppercase tracking-widest text-text-primary border-b border-border-secondary hover:border-text-primary pb-1 transition-colors duration-200 w-fit"
          data-i18n="ui.nextup.projects">My projects</a
        >
        <a
          href={`${SITE_BASE}/contact`}
          class="text-sm uppercase tracking-widest text-text-primary border-b border-border-secondary hover:border-text-primary pb-1 transition-colors duration-200 w-fit"
          data-i18n="ui.nextup.contact">Contact</a
        >
      </div>
    </nav>
  </div>
</Layout>
