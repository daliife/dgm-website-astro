---
import Layout from "../layouts/Layout.astro";
import { work } from "@cv";
import {
  TITLE_PAGE_SUFFIX,
  PAGE_CONTAINER_CLASSES,
  PAGE_HEADING_CLASSES,
} from "../utils/constants";
import { SITE_BASE } from "../utils/url";
import { t } from "../utils/i18n";
import WorkCard from "../components/sections/WorkCard.astro";
import Button from "../components/ui/Button.astro";
import type { WorkEntry } from "../types/ui";
---

<Layout
  title={`Work Experience${TITLE_PAGE_SUFFIX}`}
  description="Professional work experience of David Gimeno Mañé — Frontend Developer based in Barcelona."
>
  <div class={PAGE_CONTAINER_CLASSES}>
    <h1 class={`${PAGE_HEADING_CLASSES} mb-12`} data-i18n="ui.page.work">
      {t("ui.page.work")}
    </h1>
    <div class="reveal space-y-0">
      {work.map((job: WorkEntry, i: number) => <WorkCard {job} jobIndex={i} />)}
    </div>

    <nav
      aria-label="Related pages"
      class="reveal mt-4 border-t border-border-primary pt-8"
    >
      <p
        class="mb-5 text-xs uppercase tracking-widest text-text-muted"
        data-i18n="ui.nextup"
      >
        {t("ui.nextup")}
      </p>
      <div class="flex flex-col gap-5 sm:flex-row sm:gap-8">
        <Button
          href={`${SITE_BASE}/projects`}
          variant="simple"
          size="none"
          className="w-fit rounded-none border-b border-border-secondary pb-1 text-sm uppercase tracking-widest text-text-primary hover:border-text-primary hover:no-underline"
        >
          <span data-i18n="ui.nextup.projects">{t("ui.nextup.projects")}</span>
        </Button>
        <Button
          href={`${SITE_BASE}/contact`}
          variant="simple"
          size="none"
          className="w-fit rounded-none border-b border-border-secondary pb-1 text-sm uppercase tracking-widest text-text-primary hover:border-text-primary hover:no-underline"
        >
          <span data-i18n="ui.nextup.contact">{t("ui.nextup.contact")}</span>
        </Button>
      </div>
    </nav>
  </div>
</Layout>
