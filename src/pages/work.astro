---
import Layout from "../layouts/Layout.astro";
import { work } from "@cv";
import {
  TITLE_PAGE_SUFFIX,
  PAGE_CONTAINER_CLASSES,
  PAGE_HEADING_CLASSES,
  PAGE_HEADING_MARGIN_CLASSES,
} from "../utils/constants";
import { SITE_BASE } from "../utils/url";
import WorkCard from "../components/sections/WorkCard.astro";
import NextUpNav from "../components/layout/NextUpNav.astro";
import { t } from "../utils/i18n";
import type { WorkEntry } from "../types/ui";
---

<Layout
  title={`Work Experience${TITLE_PAGE_SUFFIX}`}
  description="Professional work experience of David Gimeno Mañé — Frontend Developer based in Barcelona."
>
  <div class={PAGE_CONTAINER_CLASSES}>
    <h1
      class={`${PAGE_HEADING_CLASSES} ${PAGE_HEADING_MARGIN_CLASSES}`}
      data-i18n="ui.page.work"
    >
      {t("ui.page.work")}
    </h1>
    <div class="reveal space-y-0 [&>article:first-child]:border-t-0">
      {work.map((job: WorkEntry, i: number) => <WorkCard {job} jobIndex={i} />)}
    </div>

    <NextUpNav
      links={[
        { href: `${SITE_BASE}/projects`, labelKey: "ui.nextup.projects" },
        { href: `${SITE_BASE}/contact`, labelKey: "ui.nextup.contact" },
      ]}
    />
  </div>
</Layout>
