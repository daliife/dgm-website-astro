---
import { SITE_BASE } from "../../utils/url";
import { t } from "../../utils/i18n";
import Button from "../ui/Button.astro";
---

<div
  id="cookie-banner"
  role="region"
  aria-label="Cookie notice"
  transition:persist
  class="fixed bottom-0 left-0 right-0 z-50 hidden translate-y-full"
>
  <div class="border-t border-border-primary bg-bg-secondary px-6 py-4">
    <div
      class="mx-auto flex max-w-5xl flex-col items-start justify-between gap-3 sm:flex-row sm:items-center"
    >
      <p class="text-xs leading-relaxed text-text-secondary">
        <span data-i18n="ui.cookies.message">{t("ui.cookies.message")}</span
        >
        {" "}
        <a
          href={`${SITE_BASE}/privacy`}
          class="underline underline-offset-4 transition-colors hover:text-text-primary"
          data-i18n="ui.cookies.learnmore"
        >
          {t("ui.cookies.learnmore")}
        </a>
      </p>
      <Button
        id="cookie-dismiss"
        variant="primary"
        size="sm"
        className="shrink-0"
      >
        <span data-i18n="ui.cookies.dismiss">{t("ui.cookies.dismiss")}</span>
      </Button>
    </div>
  </div>
</div>

<script>
  import { loadUmamiAnalytics } from "../../utils/analytics";

  const STORAGE_KEY = "cookie-consent-dismissed";

  function initBanner() {
    const banner = document.getElementById("cookie-banner");
    if (!banner) return;

    if (localStorage.getItem(STORAGE_KEY) === "true") {
      banner.classList.add("hidden");
      loadUmamiAnalytics();
      return;
    }

    banner.classList.remove("hidden");

    // Trigger slide-up animation on next frame
    requestAnimationFrame(() => {
      banner.classList.remove("translate-y-full");
      banner.classList.add(
        "translate-y-0",
        "transition-transform",
        "duration-300",
        "ease-out",
      );
    });

    const btn = document.getElementById("cookie-dismiss");
    btn?.addEventListener("click", () => {
      localStorage.setItem(STORAGE_KEY, "true");
      loadUmamiAnalytics();
      banner.classList.remove("translate-y-0");
      banner.classList.add("translate-y-full");
      banner.addEventListener(
        "transitionend",
        () => banner.classList.add("hidden"),
        { once: true },
      );
    });
  }

  document.addEventListener("astro:page-load", initBanner);
</script>
