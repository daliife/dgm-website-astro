---
import { basics } from "@cv";
import { getSocialProfile } from "../../utils/socialLinks";
import { ICON_PATHS } from "../../utils/icons";
import type { SocialProfile } from "../../types/ui";
const typedProfiles = basics.profiles as SocialProfile[];

const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    name: "LinkedIn",
    url: getSocialProfile(typedProfiles, "Linkedin")?.url || "#",
    icon: ICON_PATHS.linkedin,
  },
  {
    name: "GitHub",
    url: getSocialProfile(typedProfiles, "Github")?.url || "#",
    icon: ICON_PATHS.github,
  },
  {
    name: "Email",
    url: `mailto:${basics.email}`,
    icon: ICON_PATHS.email,
  },
];
---

<footer class="border-t border-border-primary" role="contentinfo">
  <div
    class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4"
  >
    <div class="flex items-center gap-4">
      <span class="text-xs text-text-muted">
        &copy; {currentYear}
        {basics.name}
        {basics.lastName} &mdash; Built with <span class="footer-cycle-wrapper"
          ><span class="footer-cycle">love ♥</span><span class="footer-cycle"
            >Astro 🚀</span
          ><span class="footer-cycle">AI ✦</span></span
        >
      </span>
      <a
        href="/privacy"
        class="text-xs text-text-muted hover:text-text-primary transition-colors duration-200"
        data-i18n="ui.footer.privacy"
      >
        Privacy
      </a>
    </div>
    <nav aria-label="Footer social links">
      <ul class="flex items-center gap-6">
        {
          socialLinks.map(link => (
            <li>
              <a
                href={link.url}
                target={link.name !== "Email" ? "_blank" : undefined}
                rel={link.name !== "Email" ? "noopener noreferrer" : undefined}
                class="inline-flex items-center gap-1.5 text-xs uppercase tracking-widest text-text-muted hover:text-text-primary transition-colors duration-200"
              >
                <svg
                  class="w-3.5 h-3.5 shrink-0"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  set:html={link.icon}
                />
                {link.name}
                {link.name !== "Email" && (
                  <span class="sr-only">(opens in new tab)</span>
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</footer>

<style>
  .footer-cycle-wrapper {
    display: inline-grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1em;
    overflow: hidden;
    line-height: 1;
    vertical-align: baseline;
    min-width: 3.5ch;
  }

  .footer-cycle {
    grid-area: 1 / 1;
    opacity: 0;
    transform: translateY(8px);
    animation: cycle-word 9s ease-in-out infinite;
  }

  .footer-cycle:nth-child(1) {
    animation-delay: 0s;
  }
  .footer-cycle:nth-child(2) {
    animation-delay: 3s;
  }
  .footer-cycle:nth-child(3) {
    animation-delay: 6s;
  }

  @keyframes cycle-word {
    0% {
      opacity: 0;
      transform: translateY(8px);
    }
    8% {
      opacity: 1;
      transform: translateY(0);
    }
    25% {
      opacity: 1;
      transform: translateY(0);
    }
    33% {
      opacity: 0;
      transform: translateY(-8px);
    }
    100% {
      opacity: 0;
      transform: translateY(-8px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-cycle {
      animation: none;
      opacity: 0;
    }
    .footer-cycle:nth-child(1) {
      opacity: 1;
      transform: none;
    }
  }
</style>
