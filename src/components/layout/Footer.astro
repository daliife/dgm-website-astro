---
import { basics } from "@cv";
const { profiles } = basics;

const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    name: "LinkedIn",
    url: profiles?.find((p: any) => p.network === "Linkedin")?.url || "#",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z" />`,
  },
  {
    name: "GitHub",
    url: profiles?.find((p: any) => p.network === "Github")?.url || "#",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22" />`,
  },
  {
    name: "Email",
    url: `mailto:${basics.email}`,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
  },
];
---

<footer class="border-t border-border-primary" role="contentinfo">
  <div
    class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4"
  >
    <span class="text-xs text-text-muted">
      &copy; {currentYear} David Gimeno &mdash; Built with Astro &amp; AI
    </span>
    <nav aria-label="Footer social links">
      <ul class="flex items-center gap-6">
        {
          socialLinks.map(link => (
            <li>
              <a
                href={link.url}
                target={link.name !== "Email" ? "_blank" : undefined}
                rel={link.name !== "Email" ? "noopener noreferrer" : undefined}
                class="inline-flex items-center gap-1.5 text-xs uppercase tracking-widest text-text-muted hover:text-text-primary transition-colors duration-200"
              >
                <svg
                  class="w-3.5 h-3.5 shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  set:html={link.icon}
                />
                {link.name}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</footer>
