---
import { basics } from "@cv";
import { getSocialProfile } from "../../utils/socialLinks";
import { ICON_PATHS } from "../../utils/icons";
import { SITE_BASE } from "../../utils/url";
import type { SocialProfile } from "../../types/ui";
const typedProfiles = basics.profiles as SocialProfile[];

const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    name: "LinkedIn",
    url: getSocialProfile(typedProfiles, "Linkedin")?.url || "#",
    icon: ICON_PATHS.linkedin,
  },
  {
    name: "GitHub",
    url: getSocialProfile(typedProfiles, "Github")?.url || "#",
    icon: ICON_PATHS.github,
  },
  {
    name: "Email",
    url: `mailto:${basics.email}`,
    icon: ICON_PATHS.email,
  },
];
---

<footer class="border-t border-border-primary" role="contentinfo">
  <div
    class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4"
  >
    <div
      class="flex flex-col min-[480px]:flex-row items-center gap-2 min-[480px]:gap-4"
    >
      <span class="text-xs text-text-muted text-center min-[480px]:text-left">
        &copy; <span id="footer-year">{currentYear}</span>
        {basics.name}
        {basics.lastName} &mdash; Built with <span class="footer-cycle-wrapper"
          ><span class="footer-cycle">love ♥</span><span class="footer-cycle"
            >Astro 🚀</span
          ><span class="footer-cycle">AI ✦</span></span
        >
      </span>
      <a
        href={`${SITE_BASE}/privacy`}
        class="inline-flex items-center gap-1 text-xs text-text-muted hover:text-text-primary transition-colors duration-200 shrink-0"
      >
        <svg
          class="w-3.5 h-3.5 shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
          ></path>
        </svg>
        <span data-i18n="ui.footer.privacy">Privacy</span>
      </a>
    </div>
    <nav aria-label="Footer social links">
      <ul class="flex items-center gap-6">
        {
          socialLinks.map(link => (
            <li>
              <a
                href={link.url}
                target={link.name !== "Email" ? "_blank" : undefined}
                rel={link.name !== "Email" ? "noopener noreferrer" : undefined}
                class="inline-flex items-center gap-1.5 text-xs uppercase tracking-widest text-text-muted hover:text-text-primary transition-colors duration-200"
              >
                <svg
                  class="w-3.5 h-3.5 shrink-0"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  set:html={link.icon}
                />
                {link.name}
                {link.name !== "Email" && (
                  <span class="sr-only">(opens in new tab)</span>
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</footer>

<script>
  const el = document.getElementById("footer-year");
  if (el) el.textContent = String(new Date().getFullYear());
</script>

<style>
  .footer-cycle-wrapper {
    display: inline-grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1em;
    overflow: hidden;
    line-height: 1;
    vertical-align: baseline;
    min-width: 3.5ch;
  }

  .footer-cycle {
    grid-area: 1 / 1;
    opacity: 0;
    transform: translateY(8px);
    animation: cycle-word 9s ease-in-out infinite;
  }

  .footer-cycle:nth-child(1) {
    animation-delay: 0s;
  }
  .footer-cycle:nth-child(2) {
    animation-delay: 3s;
  }
  .footer-cycle:nth-child(3) {
    animation-delay: 6s;
  }

  @keyframes cycle-word {
    0% {
      opacity: 0;
      transform: translateY(8px);
    }
    8% {
      opacity: 1;
      transform: translateY(0);
    }
    25% {
      opacity: 1;
      transform: translateY(0);
    }
    33% {
      opacity: 0;
      transform: translateY(-8px);
    }
    100% {
      opacity: 0;
      transform: translateY(-8px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-cycle {
      animation: none;
      opacity: 0;
    }
    .footer-cycle:nth-child(1) {
      opacity: 1;
      transform: none;
    }
  }
</style>
