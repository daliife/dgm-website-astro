---
interface Props {
  variant?: "primary" | "secondary" | "outline" | "ghost";
  size?: "sm" | "md" | "lg";
  href?: string;
  target?: string;
  rel?: string;
  className?: string;
  disabled?: boolean;
  loading?: boolean;
}

const {
  variant = "primary",
  size = "md",
  href,
  target,
  rel,
  className = "",
  disabled = false,
  loading = false,
} = Astro.props;

const getVariantClasses = (variant: string) => {
  switch (variant) {
    case "primary":
      return "bg-white/10 dark:bg-white/5 backdrop-blur-md border border-white/20 dark:border-white/10 text-text-primary hover:bg-white/20 dark:hover:bg-white/10 hover:border-white/30 dark:hover:border-white/20 shadow-lg hover:shadow-xl hover:shadow-primary-500/10";
    case "secondary":
      return "bg-white/5 dark:bg-white/5 backdrop-blur-md border border-white/10 dark:border-white/5 text-text-primary hover:bg-white/15 dark:hover:bg-white/10 hover:border-white/20 dark:hover:border-white/10 shadow-md hover:shadow-lg hover:shadow-primary-500/5";
    case "outline":
      return "bg-white/5 dark:bg-white/5 backdrop-blur-md border border-primary-500/30 dark:border-primary-400/30 text-text-primary hover:bg-white/15 dark:hover:bg-white/10 hover:border-primary-500/50 dark:hover:border-primary-400/50 shadow-sm hover:shadow-md hover:shadow-primary-500/5";
    case "ghost":
      return "bg-white/5 dark:bg-white/5 backdrop-blur-md border border-transparent text-text-primary hover:bg-white/10 dark:hover:bg-white/5 hover:border-white/10 dark:hover:border-white/5 shadow-sm hover:shadow-md";
    default:
      return "bg-white/10 dark:bg-white/5 backdrop-blur-md border border-white/20 dark:border-white/10 text-text-primary hover:bg-white/20 dark:hover:bg-white/10 hover:border-white/30 dark:hover:border-white/20 shadow-lg hover:shadow-xl hover:shadow-primary-500/10";
  }
};

const getSizeClasses = (size: string) => {
  switch (size) {
    case "sm":
      return "px-3 py-1.5 text-sm";
    case "md":
      return "px-4 py-2 text-base";
    case "lg":
      return "px-6 py-3 text-lg";
    default:
      return "px-4 py-2 text-base";
  }
};

const baseClasses = [
  "inline-flex",
  "items-center",
  "justify-center",
  "gap-2",
  "font-medium",
  "rounded-xl",
  "border",
  "transition-all",
  "duration-300",
  "ease-out",
  "focus:outline-none",
  "focus:ring-2",
  "focus:ring-primary-500/50",
  "focus:ring-offset-2",
  "disabled:opacity-50",
  "disabled:cursor-not-allowed",
  "disabled:transform-none",
  "hover:transform",
  "hover:-translate-y-0.5",
  "active:transform",
  "active:translate-y-0",
  "group",
  "relative",
  "overflow-hidden",
  getVariantClasses(variant),
  getSizeClasses(size),
  className,
].join(" ");

const isLink = href !== undefined;
const Tag = isLink ? "a" : "button";
const tagProps = isLink
  ? { href, target, rel }
  : { disabled: disabled || loading };
---

<Tag class={baseClasses} {...tagProps}>
  <!-- Glass effect overlay -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-white/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-xl"
  >
  </div>

  {
    loading && (
      <svg
        class="animate-spin h-4 w-4"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
      >
        <circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"
        />
        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        />
      </svg>
    )
  }
  <slot />
</Tag>
