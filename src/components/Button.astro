---
interface Props {
  variant?: "primary" | "secondary" | "outline" | "ghost";
  size?: "sm" | "md" | "lg";
  href?: string;
  target?: string;
  rel?: string;
  className?: string;
  disabled?: boolean;
  loading?: boolean;
}

const {
  variant = "primary",
  size = "md",
  href,
  target,
  rel,
  className = "",
  disabled = false,
  loading = false,
} = Astro.props;

const getVariantClasses = (variant: string) => {
  switch (variant) {
    case "primary":
      return "bg-gradient-to-br from-deep-blue-600 via-ocean-600 to-steel-600 hover:from-deep-blue-700 hover:via-ocean-700 hover:to-steel-700 text-white border-0 shadow-lg hover:shadow-2xl hover:shadow-deep-blue-500/25 backdrop-blur-sm";
    case "secondary":
      return "bg-gradient-to-br from-deep-blue-50/80 to-ocean-50/80 hover:from-deep-blue-100/90 hover:to-ocean-100/90 text-deep-blue-700 border border-deep-blue-200/50 shadow-md hover:shadow-lg hover:shadow-deep-blue-200/20 backdrop-blur-sm dark:from-deep-blue-900/30 dark:to-ocean-900/30 dark:hover:from-deep-blue-900/50 dark:hover:to-ocean-900/50 dark:text-deep-blue-300 dark:border-deep-blue-700/50";
    case "outline":
      return "bg-gradient-to-br from-transparent to-transparent hover:from-deep-blue-50/60 hover:to-ocean-50/60 text-deep-blue-600 border-2 border-gradient-to-r border-deep-blue-600 hover:border-deep-blue-700 shadow-sm hover:shadow-md hover:shadow-deep-blue-200/10 backdrop-blur-sm dark:text-deep-blue-400 dark:border-deep-blue-400 dark:hover:from-deep-blue-900/20 dark:hover:to-ocean-900/20";
    case "ghost":
      return "bg-gradient-to-br from-transparent to-transparent hover:from-deep-blue-50/40 hover:to-ocean-50/40 text-deep-blue-600 border-0 shadow-sm hover:shadow-md hover:shadow-deep-blue-200/5 backdrop-blur-sm dark:text-deep-blue-400 dark:hover:from-deep-blue-900/15 dark:hover:to-ocean-900/15";
    default:
      return "bg-gradient-to-br from-deep-blue-600 via-ocean-600 to-steel-600 hover:from-deep-blue-700 hover:via-ocean-700 hover:to-steel-700 text-white border-0 shadow-lg hover:shadow-2xl hover:shadow-deep-blue-500/25 backdrop-blur-sm";
  }
};

const getSizeClasses = (size: string) => {
  switch (size) {
    case "sm":
      return "px-3 py-1.5 text-sm";
    case "md":
      return "px-4 py-2 text-base";
    case "lg":
      return "px-6 py-3 text-lg";
    default:
      return "px-4 py-2 text-base";
  }
};

const baseClasses = [
  "inline-flex",
  "items-center",
  "justify-center",
  "font-medium",
  "rounded-full",
  "border",
  "transition-all",
  "duration-500",
  "ease-out",
  "focus:outline-none",
  "focus:ring-2",
  "focus:ring-deep-blue-500",
  "focus:ring-offset-2",
  "disabled:opacity-50",
  "disabled:cursor-not-allowed",
  "disabled:transform-none",
  "hover:transform",
  "hover:-translate-y-0.5",
  "active:transform",
  "active:translate-y-0",
  getVariantClasses(variant),
  getSizeClasses(size),
  className,
].join(" ");

const isLink = href !== undefined;
const Tag = isLink ? "a" : "button";
const tagProps = isLink
  ? { href, target, rel }
  : { disabled: disabled || loading };
---

<Tag class={baseClasses} {...tagProps}>
  {
    loading && (
      <svg
        class="animate-spin -ml-1 mr-2 h-4 w-4"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
      >
        <circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"
        />
        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        />
      </svg>
    )
  }
  <slot />
</Tag>
