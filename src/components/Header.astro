---
import DarkModeButton from "./DarkModeButton.astro";
import DgmLogoSimple from "./DgmLogoSimple.astro";
import { NAV_LINKS } from "../utils/constants";
const { pathname } = Astro.url;
---

<nav class="w-full max-w-7xl mx-auto z-20 top-0 start-0 bg-transparent">
  <div
    class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8"
  >
    <a
      href={import.meta.env.BASE_URL}
      class="flex items-center space-x-3 rtl:space-x-reverse"
    >
      <DgmLogoSimple
        className={`fill-text-primary hover:fill-text-accent transition-colors duration-300 ${
          pathname === "/dgm-website-astro/" ||
          pathname === "/dgm-website-astro"
            ? "fill-text-accent"
            : ""
        }`}
        size="24px"
      />
    </a>
    <div
      class="flex md:order-2 space-x-3 sm:space-x-4 md:space-x-0 rtl:space-x-reverse"
    >
      <DarkModeButton />
      <button
        data-collapse-toggle="navbar-sticky"
        type="button"
        class="inline-flex items-center p-3 w-12 h-12 justify-center text-sm text-text-primary rounded-lg md:hidden hover:bg-bg-muted hover:text-text-accent focus:outline-none focus:ring-2 focus:ring-primary-200 dark:focus:ring-primary-600 transition-colors duration-200"
        aria-controls="navbar-sticky"
        aria-expanded="false"
        aria-label="Toggle navigation menu"
        onclick="toggleMobileMenu(this)"
      >
        <span class="sr-only">Open main menu</span>
        <svg
          class="w-5 h-5"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 17 14"
        >
          <path
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M1 1h15M1 7h15M1 13h15"></path>
        </svg>
      </button>
    </div>
    <div
      class="items-center justify-between hidden w-full fixed top-0 left-0 h-screen bg-bg-primary z-50 md:flex md:w-auto md:order-1 md:relative md:h-auto md:bg-transparent"
      id="navbar-sticky"
    >
      <button
        onclick="closeMobileMenu()"
        class="absolute top-6 right-6 p-3 text-text-primary hover:text-text-accent hover:bg-bg-muted md:hidden transition-colors duration-200"
        aria-label="Close navigation menu"
      >
        <span class="sr-only">Close menu</span>
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
      <ul
        class="flex flex-col p-8 sm:p-10 mt-20 sm:mt-24 md:mt-0 font-medium w-full text-center md:text-left md:p-0 md:space-x-8 lg:space-x-10 rtl:space-x-reverse md:flex-row"
      >
        {
          NAV_LINKS.map(page => (
            <li>
              <a
                href={page === "home" ? import.meta.env.BASE_URL : `/${page}`}
                class:list={[
                  "block py-4 px-5 sm:py-5 sm:px-7 md:p-0 text-text-primary hover:text-text-accent hover:underline underline-offset-4 text-lg sm:text-xl md:text-lg transition-all duration-300",
                  {
                    "text-text-accent font-bold bg-bg-muted rounded-lg md:bg-bg-secondary md:rounded-md md:px-3 md:py-2 md:shadow-sm md:border md:border-border-primary md:relative md:after:content-[''] md:after:absolute md:after:-bottom-1 md:after:left-1/2 md:after:transform md:after:-translate-x-1/2 md:after:w-2 md:after:h-2 md:after:bg-text-accent md:after:rounded-full":
                      pathname === "/dgm-website-astro/" + page ||
                      (pathname === "/dgm-website-astro/" && page === "home"),
                  },
                ]}
                aria-current="page"
              >
                {page.charAt(0).toUpperCase() + page.slice(1)}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</nav>

<script is:inline>
  function toggleMobileMenu(button) {
    const menu = document.getElementById("navbar-sticky");
    const isExpanded = menu.classList.contains("hidden");

    if (isExpanded) {
      menu.classList.remove("hidden");
      button.setAttribute("aria-expanded", "true");
    } else {
      menu.classList.add("hidden");
      button.setAttribute("aria-expanded", "false");
    }
  }

  function closeMobileMenu() {
    const menu = document.getElementById("navbar-sticky");
    const button = document.querySelector(
      '[data-collapse-toggle="navbar-sticky"]'
    );

    menu.classList.add("hidden");
    if (button) {
      button.setAttribute("aria-expanded", "false");
    }
  }
</script>
