---
import { GRID_SYSTEMS } from "../utils/constants";

interface Props {
  variant?: "projects" | "responsive" | "custom";
  columns?: {
    mobile?: number;
    sm?: number;
    md?: number;
    lg?: number;
    xl?: number;
    "2xl"?: number;
    "3xl"?: number;
  };
  gap?: "sm" | "md" | "lg" | "xl";
  className?: string;
}

const {
  variant = "responsive",
  columns,
  gap = "md",
  className = "",
} = Astro.props;

const getGridClasses = (variant: string, customColumns?: any) => {
  if (variant === "custom" && customColumns) {
    const classes = ["grid"];

    // Add column classes based on custom columns
    if (customColumns.mobile) classes.push(`grid-cols-${customColumns.mobile}`);
    if (customColumns.sm) classes.push(`sm:grid-cols-${customColumns.sm}`);
    if (customColumns.md) classes.push(`md:grid-cols-${customColumns.md}`);
    if (customColumns.lg) classes.push(`lg:grid-cols-${customColumns.lg}`);
    if (customColumns.xl) classes.push(`xl:grid-cols-${customColumns.xl}`);
    if (customColumns["2xl"])
      classes.push(`2xl:grid-cols-${customColumns["2xl"]}`);
    if (customColumns["3xl"])
      classes.push(`3xl:grid-cols-${customColumns["3xl"]}`);

    return classes.join(" ");
  }

  const gridSystem = GRID_SYSTEMS[variant as keyof typeof GRID_SYSTEMS];
  if (!gridSystem) {
    return "grid grid-cols-1";
  }

  // Explicitly list all grid classes for proper responsive behavior
  const gridClasses = [
    "grid",
    gridSystem.MOBILE,
    gridSystem.SM,
    gridSystem.MD,
    gridSystem.LG,
    gridSystem.XL,
    "2XL" in gridSystem ? gridSystem["2XL"] : undefined,
    "3XL" in gridSystem ? gridSystem["3XL"] : undefined,
  ].filter(Boolean);

  return gridClasses.join(" ");
};

const getGapClasses = (gap: string) => {
  switch (gap) {
    case "sm":
      return "gap-2 sm:gap-3 lg:gap-4";
    case "md":
      return "gap-4 sm:gap-6 lg:gap-8";
    case "lg":
      return "gap-6 sm:gap-8 lg:gap-12";
    case "xl":
      return "gap-8 sm:gap-12 lg:gap-16";
    default:
      return "gap-4 sm:gap-6 lg:gap-8";
  }
};

const classes = [
  getGridClasses(variant, columns),
  getGapClasses(gap),
  className,
].join(" ");
---

<div class={classes}>
  <slot />
</div>
