---
const { id, title } = Astro.props;
---

<section id={id} class="mx-0 sm:mx-2 lg:mx-4 my-6 sm:my-8 lg:my-12">
  {
    title && (
      <h2
        class="text-text-primary-light dark:text-text-primary-dark text-xl sm:text-2xl lg:text-3xl font-semibold mb-6 sm:mb-8 lg:mb-10 text-center sm:text-left"
        transition:name="section-name"
      >
        {title}
      </h2>
    )
  }
  <div class="w-full">
    <slot />
  </div>
</section>
