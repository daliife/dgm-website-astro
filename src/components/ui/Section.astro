---
import { SPACING } from "../../utils/constants";

const { id, title, className = "" } = Astro.props;

const sectionClasses = [
  SPACING.SECTION.MOBILE,
  SPACING.SECTION.SM,
  SPACING.SECTION.LG,
  className,
].join(" ");
---

<section id={id} class={sectionClasses}>
  {
    title && (
      <h2
        class="text-text-primary text-xl sm:text-2xl lg:text-3xl font-semibold mb-6 sm:mb-8 lg:mb-10 text-center sm:text-left"
        transition:name="section-name"
      >
        {title}
      </h2>
    )
  }
  <div class="w-full">
    <slot />
  </div>
</section>
