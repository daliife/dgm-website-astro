---
import type { ButtonVariant, ButtonSize } from "../../types/ui";

interface Props {
  variant?: ButtonVariant;
  size?: ButtonSize;
  href?: string;
  target?: string;
  rel?: string;
  download?: string;
  className?: string;
  disabled?: boolean;
  loading?: boolean;
  onclick?: string;
  id?: string;
  "aria-label"?: string;
  "aria-expanded"?: string;
  "aria-controls"?: string;
  "data-collapse-toggle"?: string;
}

const {
  variant = "primary",
  size = "md",
  href,
  target,
  rel,
  download,
  className = "",
  disabled = false,
  loading = false,
  onclick,
  id,
  "aria-label": ariaLabel,
  "aria-expanded": ariaExpanded,
  "aria-controls": ariaControls,
  "data-collapse-toggle": dataCollapseToggle,
} = Astro.props;

// Base classes that apply to all buttons - Minimalista
const baseClasses =
  " inline-flex items-center justify-center gap-3 font-medium transition-all duration-300 ease-out rounded-lg disabled:opacity-50 disabled:cursor-not-allowed";

// Variant classes - Minimalist design with subtle animations
const variantClasses: Record<ButtonVariant, string> = {
  primary:
    "bg-text-primary text-bg-primary hover:opacity-90 hover:scale-[1.02] active:scale-[0.98]",
  secondary:
    "bg-bg-muted text-text-primary hover:bg-bg-secondary hover:scale-[1.02] active:scale-[0.98]",
  outline:
    "border border-border-secondary text-text-primary hover:border-text-primary hover:bg-bg-muted/50 hover:scale-[1.02] active:scale-[0.98]",
  ghost:
    "text-text-secondary hover:bg-bg-muted hover:text-text-primary",
  simple:
    "text-text-muted hover:text-text-primary underline-offset-4 hover:underline",
  icon: "text-text-muted hover:text-text-primary hover:bg-bg-muted rounded-full",
};

// Size classes
const sizeClasses: Record<ButtonSize, string> = {
  sm: "px-4 py-2 text-sm",
  md: "px-6 py-2.5 text-base",
  lg: "px-7 py-3.5 text-lg",
  icon: "p-2",
};

// Build final class string
const buttonClasses = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`;

const isLink = href !== undefined;
const Tag = isLink ? "a" : "button";

// Prepare common attributes
const commonAttrs: any = {};
if (id) commonAttrs.id = id;
if (onclick) commonAttrs.onclick = onclick;
if (ariaLabel) commonAttrs["aria-label"] = ariaLabel;
if (ariaExpanded) commonAttrs["aria-expanded"] = ariaExpanded;
if (ariaControls) commonAttrs["aria-controls"] = ariaControls;
if (dataCollapseToggle)
  commonAttrs["data-collapse-toggle"] = dataCollapseToggle;

const tagProps = isLink
  ? { href, target, rel, download, ...commonAttrs }
  : { disabled: disabled || loading, ...commonAttrs };
---

<Tag class={buttonClasses} {...tagProps}>
  {
    loading && (
      <svg
        class="animate-spin h-4 w-4"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
      >
        <circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"
        />
        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        />
      </svg>
    )
  }
  <slot />
</Tag>
