---
import { Image } from "astro:assets";
import { PROJECT_CARD_DIMENSIONS, IMAGE_LOADING } from "../utils/constants";

interface Props {
  name: string;
  image: string;
  url: string;
  description: string;
  technologies?: string[];
}

const { name, image, url, description, technologies = [] } = Astro.props;

// Validacions
if (!name || !url) {
  throw new Error("Project component requires 'name' and 'url' props");
}

if (!image) {
  console.warn(`Project "${name}" is missing an image`);
}
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="project-card group relative w-full h-auto rounded-xl overflow-hidden cursor-pointer transition-all duration-300 ease-out hover:transform hover:-translate-y-2 hover:shadow-2xl hover:ring-2 hover:ring-border-primary hover:ring-opacity-50 bg-bg-primary"
  aria-label={`View project: ${name}`}
>
  <!-- Full image -->
  <div class="relative w-full overflow-hidden project-image">
    <Image
      src={image}
      alt={name}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500 ease-out"
      width={PROJECT_CARD_DIMENSIONS.width}
      height={PROJECT_CARD_DIMENSIONS.height}
      loading={IMAGE_LOADING}
    />
    <!-- Overlay gradient -->
    <div
      class="absolute inset-0 bg-gradient-to-t from-bg-primary/80 via-bg-primary/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
    >
    </div>
  </div>

  <!-- Title at bottom (always visible) -->
  <div
    class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-bg-primary/90 via-bg-primary/50 to-transparent"
  >
    <h2
      class="text-text-primary text-xl font-bold leading-tight group-hover:text-text-primary transition-colors duration-300"
    >
      {name}
    </h2>
  </div>

  <!-- Hover content (description and tags) -->
  <div
    class="absolute inset-0 bg-gradient-to-t from-bg-primary/95 via-bg-secondary/80 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-300 flex flex-col justify-end p-4"
  >
    <!-- Click indicator -->
    <div
      class="absolute top-3 right-3 bg-bg-secondary/80 backdrop-blur-sm rounded-full p-2 group-hover:bg-bg-muted/90 transition-all duration-300"
    >
      <svg
        class="w-4 h-4 text-text-secondary group-hover:text-text-primary group-hover:scale-110 transition-all duration-300"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2.5"
          d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
        ></path>
      </svg>
    </div>

    <!-- Description -->
    <p
      class="text-text-secondary text-sm leading-relaxed mb-3 group-hover:text-text-primary transition-colors duration-300"
    >
      {description}
    </p>

    <!-- Tags -->
    {
      technologies.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {technologies.map(tech => (
            <span class="px-2 py-1 text-xs font-medium bg-bg-muted/60 text-text-secondary rounded-full backdrop-blur-sm group-hover:bg-bg-muted/80 group-hover:text-text-primary transition-all duration-200">
              {tech}
            </span>
          ))}
        </div>
      )
    }
  </div>
</a>

<style>
  .project-image {
    height: 200px; /* Fixed height for full image layout */
  }

  /* Responsive heights for full image layout */
  @media (min-width: 640px) {
    .project-image {
      height: 220px; /* Slightly larger on small screens */
    }
  }

  @media (min-width: 1024px) {
    .project-image {
      height: 250px; /* Larger on desktop */
    }
  }

  @media (min-width: 1280px) {
    .project-image {
      height: 280px; /* Even larger on xl screens */
    }
  }

  @media (min-width: 1536px) {
    .project-image {
      height: 300px; /* Maximum height for 2xl screens */
    }
  }

  @media (min-width: 1920px) {
    .project-image {
      height: 320px; /* Ultra-wide screens */
    }
  }

  /* Mobile responsive adjustments */
  @media (max-width: 480px) {
    .project-image {
      height: 180px !important;
    }
  }
</style>
