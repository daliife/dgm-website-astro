---
import { Image } from "astro:assets";
import { PROJECT_CARD_DIMENSIONS, IMAGE_LOADING } from "../utils/constants";

interface Props {
  name: string;
  image: string;
  url: string;
  description: string;
  technologies?: string[];
}

const { name, image, url, description, technologies = [] } = Astro.props;

// Validacions
if (!name || !url) {
  throw new Error("Project component requires 'name' and 'url' props");
}

if (!image) {
  console.warn(`Project "${name}" is missing an image`);
}
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="flex flex-col items-start justify-center
w-full h-auto rounded-xl text-text-primary-light dark:text-text-primary-dark bg-bg-light/95 dark:bg-bg-dark-alt/90 hover:transform hover:-translate-y-2 hover:bg-deep-blue-50 dark:hover:bg-deep-blue-900/20 shadow-sm hover:shadow-2xl border border-deep-blue-200/60 dark:border-border-dark hover:border-deep-blue-300 dark:hover:border-deep-blue-600 backdrop-blur-sm transition-all duration-300 ease-out group cursor-pointer"
  aria-label={`View project: ${name}`}
>
  <div class="relative w-full overflow-hidden rounded-t-xl project-image">
    <Image
      src={image}
      alt={name}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500 ease-out"
      width={PROJECT_CARD_DIMENSIONS.width}
      height={PROJECT_CARD_DIMENSIONS.height}
      loading={IMAGE_LOADING}
    />
    <div
      class="absolute inset-0 bg-gradient-to-t from-black/30 via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
    >
    </div>
  </div>
  <div
    class="flex flex-col items-start w-full h-full justify-center p-4 sm:p-5 relative"
  >
    <!-- Subtle click indicator -->
    <div
      class="absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
    >
      <svg
        class="w-4 h-4 text-deep-blue-600"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
        ></path>
      </svg>
    </div>
    <h2
      class="text-sm sm:text-base md:text-lg font-semibold text-text-primary-light dark:text-text-primary-dark leading-tight group-hover:text-deep-blue-600 dark:group-hover:text-deep-blue-400 transition-colors duration-300"
    >
      {name}
    </h2>
    <p
      class="mt-2 text-xs sm:text-sm md:text-base text-text-muted-light dark:text-text-muted-dark leading-relaxed line-clamp-2 group-hover:text-text-secondary-light dark:group-hover:text-text-secondary-dark transition-colors duration-300"
    >
      {description}
    </p>
    {
      technologies.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5 sm:gap-2">
          {technologies.map(tech => (
            <span class="px-2.5 py-1 text-xs font-medium bg-deep-blue-100 dark:bg-deep-blue-900/50 text-deep-blue-700 dark:text-deep-blue-300 rounded-full group-hover:bg-deep-blue-200 dark:group-hover:bg-deep-blue-900/30 group-hover:text-deep-blue-800 dark:group-hover:text-deep-blue-300 transition-all duration-200">
              {tech}
            </span>
          ))}
        </div>
      )
    }
  </div>
</a>

<style>
  .project-image {
    height: 180px; /* Reduced base height */
  }

  /* Varied heights for puzzle effect - more proportional */
  :nth-child(3n + 1) .project-image {
    height: 200px;
  }

  :nth-child(3n + 2) .project-image {
    height: 160px;
  }

  :nth-child(3n + 3) .project-image {
    height: 180px;
  }

  :nth-child(4n + 1) .project-image {
    height: 200px;
  }

  :nth-child(4n + 2) .project-image {
    height: 160px;
  }

  :nth-child(4n + 3) .project-image {
    height: 140px;
  }

  :nth-child(4n + 4) .project-image {
    height: 190px;
  }

  :nth-child(5n + 1) .project-image {
    height: 200px;
  }

  :nth-child(5n + 2) .project-image {
    height: 160px;
  }

  :nth-child(5n + 3) .project-image {
    height: 140px;
  }

  :nth-child(5n + 4) .project-image {
    height: 190px;
  }

  :nth-child(5n + 5) .project-image {
    height: 170px;
  }

  :nth-child(6n + 1) .project-image {
    height: 200px;
  }

  :nth-child(6n + 2) .project-image {
    height: 160px;
  }

  :nth-child(6n + 3) .project-image {
    height: 140px;
  }

  :nth-child(6n + 4) .project-image {
    height: 190px;
  }

  :nth-child(6n + 5) .project-image {
    height: 170px;
  }

  :nth-child(6n + 6) .project-image {
    height: 185px;
  }

  /* Responsive heights */
  @media (min-width: 640px) {
    .project-image {
      height: 160px; /* Smaller on small screens */
    }

    :nth-child(2n + 1) .project-image {
      height: 180px;
    }

    :nth-child(2n + 2) .project-image {
      height: 140px;
    }
  }

  @media (min-width: 1024px) {
    .project-image {
      height: 180px; /* Optimized for desktop */
    }

    :nth-child(3n + 1) .project-image {
      height: 200px;
    }

    :nth-child(3n + 2) .project-image {
      height: 160px;
    }

    :nth-child(3n + 3) .project-image {
      height: 180px;
    }
  }

  @media (min-width: 1280px) {
    .project-image {
      height: 180px; /* Keep same height for xl screens */
    }

    :nth-child(4n + 1) .project-image {
      height: 200px;
    }

    :nth-child(4n + 2) .project-image {
      height: 160px;
    }

    :nth-child(4n + 3) .project-image {
      height: 140px;
    }

    :nth-child(4n + 4) .project-image {
      height: 190px;
    }
  }

  @media (min-width: 1536px) {
    .project-image {
      height: 180px; /* Keep same height for 2xl screens */
    }

    :nth-child(5n + 1) .project-image {
      height: 200px;
    }

    :nth-child(5n + 2) .project-image {
      height: 160px;
    }

    :nth-child(5n + 3) .project-image {
      height: 140px;
    }

    :nth-child(5n + 4) .project-image {
      height: 190px;
    }

    :nth-child(5n + 5) .project-image {
      height: 170px;
    }
  }

  @media (min-width: 1920px) {
    .project-image {
      height: 180px; /* Keep same height for ultra-wide screens */
    }

    :nth-child(6n + 1) .project-image {
      height: 200px;
    }

    :nth-child(6n + 2) .project-image {
      height: 160px;
    }

    :nth-child(6n + 3) .project-image {
      height: 140px;
    }

    :nth-child(6n + 4) .project-image {
      height: 190px;
    }

    :nth-child(6n + 5) .project-image {
      height: 170px;
    }

    :nth-child(6n + 6) .project-image {
      height: 185px;
    }
  }
</style>
