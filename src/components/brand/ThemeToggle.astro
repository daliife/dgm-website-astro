---
import { t } from "../../utils/i18n";
---

<button
  data-theme-toggle
  type="button"
  aria-label={t("ui.a11y.theme.toDark")}
  aria-pressed="false"
  class="rounded-full p-2 text-text-secondary transition-colors duration-200 hover:bg-bg-muted hover:text-text-primary"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg
    class="hidden h-5 w-5 dark:block"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.5"
      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
    ></path>
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg
    class="block h-5 w-5 dark:hidden"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.5"
      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
    ></path>
  </svg>
</button>

<script>
  import { getStoredLang, loadLang } from "../../utils/i18n-client";
  import type { LangCode } from "../../utils/i18n";

  async function setToggleState(
    toggle: HTMLButtonElement,
    isDark: boolean,
    lang: LangCode,
  ) {
    const translations = await loadLang(lang);
    toggle.setAttribute("aria-pressed", String(isDark));
    toggle.setAttribute(
      "aria-label",
      isDark
        ? translations["ui.a11y.theme.toLight"]
        : translations["ui.a11y.theme.toDark"],
    );
  }

  function initThemeToggle(toggle: HTMLButtonElement) {
    if (toggle.dataset.init) return;
    toggle.dataset.init = "true";

    const syncState = () => {
      const isDark = document.documentElement.classList.contains("dark");
      void setToggleState(toggle, isDark, getStoredLang());
    };

    syncState();

    toggle.addEventListener("click", () => {
      const isDark = document.documentElement.classList.contains("dark");
      if (isDark) {
        document.documentElement.classList.remove("dark");
        localStorage.setItem("theme", "light");
      } else {
        document.documentElement.classList.add("dark");
        localStorage.setItem("theme", "dark");
      }
      void setToggleState(toggle, !isDark, getStoredLang());
    });
  }

  document.addEventListener("astro:page-load", () => {
    document
      .querySelectorAll<HTMLButtonElement>("[data-theme-toggle]")
      .forEach(initThemeToggle);
  });

  window.addEventListener("app:lang-change", (e: Event) => {
    const { lang } = (e as CustomEvent<{ lang: LangCode }>).detail;
    document
      .querySelectorAll<HTMLButtonElement>("[data-theme-toggle]")
      .forEach((toggle) => {
        const isDark = document.documentElement.classList.contains("dark");
        void setToggleState(toggle, isDark, lang);
      });
  });
</script>
