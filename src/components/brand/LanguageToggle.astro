---
import { SUPPORTED_LANGUAGES } from "../../utils/constants";
interface Props {
  dropup?: boolean;
}
const { dropup = false } = Astro.props;
---

<div data-lang-switcher class="relative">
  <button
    type="button"
    data-lang-toggle-btn
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label="Select language"
    class="flex items-center gap-1.5 rounded-full p-2 text-text-secondary transition-colors duration-200 hover:bg-bg-muted hover:text-text-primary"
  >
    <svg
      class="h-4 w-4 shrink-0"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <circle
        cx="12"
        cy="12"
        r="9"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></circle>
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="M3.6 9h16.8M3.6 15h16.8M12 3c-2 2.5-3 5.5-3 9s1 6.5 3 9M12 3c2 2.5 3 5.5 3 9s-1 6.5-3 9"
      ></path>
    </svg>
    <span data-lang-current class="text-xs font-medium tracking-wide">CA</span>
    <svg
      class="h-3 w-3"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d={dropup ? "M5 15l7-7 7 7" : "M19 9l-7 7-7-7"}></path>
    </svg>
  </button>

  <div
    data-lang-dropdown
    role="listbox"
    aria-label="Language"
    class={`absolute right-0 ${dropup ? "bottom-full mb-1" : "top-full mt-1"} hidden z-50 bg-bg-primary border border-border-primary rounded-lg shadow-lg py-1 min-w-[5.5rem]`}
  >
    {
      SUPPORTED_LANGUAGES.map((lang) => (
        <button
          type="button"
          role="option"
          data-lang-btn={lang.code}
          aria-selected={lang.default ? "true" : "false"}
          class="w-full px-3 py-1.5 text-left text-xs tracking-wide text-text-secondary transition-colors duration-150 hover:bg-bg-secondary hover:text-text-primary"
        >
          {lang.nativeName}
        </button>
      ))
    }
  </div>
</div>

<script>
  import {
    applyI18n,
    getStoredLang,
    preloadStoredLang,
  } from "../../utils/i18n-client";
  import type { LangCode } from "../../utils/i18n";

  preloadStoredLang();

  document.addEventListener("click", async (e) => {
    const langBtn = (e.target as Element).closest(
      "[data-lang-btn]",
    ) as HTMLElement | null;

    if (langBtn?.dataset.langBtn) {
      const lang = langBtn.dataset.langBtn as LangCode;
      localStorage.setItem("lang", lang);
      await applyI18n(lang);
      window.dispatchEvent(
        new CustomEvent("app:lang-change", { detail: { lang } }),
      );
      const switcher = langBtn.closest("[data-lang-switcher]");
      switcher?.querySelector("[data-lang-dropdown]")?.classList.add("hidden");
      switcher
        ?.querySelector("[data-lang-toggle-btn]")
        ?.setAttribute("aria-expanded", "false");
      return;
    }

    if (!(e.target as Element).closest("[data-lang-switcher]")) {
      document
        .querySelectorAll("[data-lang-dropdown]")
        .forEach((d) => d.classList.add("hidden"));
      document
        .querySelectorAll("[data-lang-toggle-btn]")
        .forEach((b) => b.setAttribute("aria-expanded", "false"));
    }
  });

  document.addEventListener("astro:page-load", async () => {
    const lang = getStoredLang();
    await applyI18n(lang);

    document
      .querySelectorAll<HTMLElement>("[data-lang-toggle-btn]")
      .forEach((btn) => {
        if (btn.dataset.init) return;
        btn.dataset.init = "true";
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          const switcher = btn.closest("[data-lang-switcher]");
          const dropdown = switcher?.querySelector("[data-lang-dropdown]");
          const isOpen = !dropdown?.classList.contains("hidden");
          document
            .querySelectorAll("[data-lang-dropdown]")
            .forEach((d) => d.classList.add("hidden"));
          document
            .querySelectorAll("[data-lang-toggle-btn]")
            .forEach((b) => b.setAttribute("aria-expanded", "false"));
          if (!isOpen) {
            dropdown?.classList.remove("hidden");
            btn.setAttribute("aria-expanded", "true");
          }
        });
      });
  });
</script>
