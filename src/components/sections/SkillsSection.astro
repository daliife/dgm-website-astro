---
import type { SkillEntry } from "../../types/ui";
import type { I18nKey } from "../../i18n/en";
import { ABOUT_SECTION_SPACING_CLASSES } from "../../utils/constants";
import { t } from "../../utils/i18n";

interface Props {
  skills: SkillEntry[];
}

const { skills } = Astro.props;
---

<section class={`reveal ${ABOUT_SECTION_SPACING_CLASSES}`}>
  <h2
    class="mb-10 text-3xl font-bold uppercase tracking-tight text-text-primary sm:text-4xl print:mb-1.5 print:border-b print:border-gray-300 print:pb-0.5 print:text-[10px] print:font-medium print:normal-case print:tracking-widest print:text-black"
    data-i18n="ui.about.skills"
  >
    {t("ui.about.skills")}
  </h2>
  <div
    class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3 print:block print:space-y-3"
  >
    {
      skills.map((skill: SkillEntry, skillIndex: number) => (
        <div class="print:flex print:items-baseline print:gap-x-2">
          <h3 class="mb-3 text-sm uppercase tracking-widest text-text-muted print:mb-0 print:shrink-0 print:text-[10px] print:font-medium print:text-gray-900">
            <span data-i18n={`skills.${skillIndex}.name`}>
              {t(`skills.${skillIndex}.name` as I18nKey, skill.name)}
            </span>
            <span class="hidden print:inline">:</span>
          </h3>
          <p
            class="mb-2 text-sm text-text-secondary print:hidden"
            data-i18n={`skills.${skillIndex}.level`}
          >
            {t(`skills.${skillIndex}.level` as I18nKey, skill.level)}
          </p>
          <div class="flex flex-wrap gap-2 print:contents">
            {skill.keywords.map((keyword: string, i: number) => (
              <span class="rounded-full border border-border-primary px-3 py-1 text-xs text-text-secondary print:inline print:rounded-none print:border-0 print:p-0 print:text-[10px] print:text-gray-600">
                {keyword}
                {i < skill.keywords.length - 1 ? (
                  <span class="hidden print:inline">,&nbsp;</span>
                ) : null}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
