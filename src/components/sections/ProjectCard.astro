---
import type { ProjectEntry } from "../../types/ui";
import type { I18nKey } from "../../i18n/en";
import { t } from "../../utils/i18n";

interface Props {
  project: ProjectEntry;
  projectIndex: number;
  priority?: boolean;
}

const { project, projectIndex, priority = false } = Astro.props;
const descriptionKey = `projects.${projectIndex}.description` as I18nKey;
---

<article
  class="group border-t border-border-primary py-8"
  aria-labelledby={`project-${projectIndex}-title`}
>
  <a
    href={project.url ?? undefined}
    target={project.url ? "_blank" : undefined}
    rel={project.url ? "noopener noreferrer" : undefined}
    class="flex min-w-0 flex-row items-start gap-5 overflow-hidden sm:gap-10"
  >
    <div
      class="img-frame relative h-24 w-24 shrink-0 overflow-hidden bg-bg-muted sm:h-32 sm:w-48"
    >
      <div
        class="flex h-full w-full items-center justify-center text-text-muted"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
          <circle cx="8.5" cy="8.5" r="1.5"></circle>
          <polyline points="21 15 16 10 5 21"></polyline>
        </svg>
      </div>
      {
        project.image && (
          <img
            src={project.image}
            alt={project.name}
            class="absolute inset-0 h-full w-full object-cover transition-all duration-300 ease-out [@media(hover:hover)]:group-hover:scale-[1.04] [@media(hover:hover)]:group-hover:grayscale"
            loading={priority ? "eager" : "lazy"}
            decoding="async"
            width="192"
            height="128"
            {...(priority ? { fetchpriority: "high" } : {})}
            data-use-fallback
          />
        )
      }
    </div>
    <div class="min-w-0 flex-1">
      <div
        class="mb-2 flex flex-col gap-1 sm:mb-3 sm:flex-row sm:items-baseline sm:justify-between sm:gap-2"
      >
        <h3
          id={`project-${projectIndex}-title`}
          class="project-title text-xl font-semibold text-text-primary transition-colors duration-200 ease-out sm:text-2xl"
        >
          {project.name}
        </h3>
        <span
          class="text-xs uppercase tracking-widest text-text-muted sm:whitespace-nowrap"
        >
          {project.technologies?.join(" · ")}
        </span>
      </div>
      <p
        class="text-sm leading-relaxed text-text-secondary sm:text-base"
        data-i18n={descriptionKey}
      >
        {t(descriptionKey, project.description)}
      </p>
    </div>
    <span class="sr-only">(opens in new tab)</span>
  </a>
</article>

<script>
  document.addEventListener("astro:page-load", () => {
    const imgs = document.querySelectorAll<HTMLImageElement>(
      "img[data-use-fallback]",
    );
    if (!imgs.length) return;
    imgs.forEach((img) => {
      if (img.dataset.fallbackBound) return;
      img.dataset.fallbackBound = "true";
      img.addEventListener("error", function () {
        this.remove();
      });
    });
  });
</script>

<style>
  @media (hover: hover) {
    .project-title {
      background-image: linear-gradient(currentColor, currentColor);
      background-size: 0% 1px;
      background-repeat: no-repeat;
      background-position: left bottom;
      transition:
        background-size 0.25s ease,
        color 0.2s ease;
      padding-bottom: 1px;
    }
    .group:hover .project-title {
      background-size: 100% 1px;
    }
  }
</style>
