---
import type { LanguageEntry } from "../../types/ui";
import type { I18nKey } from "../../i18n/en";
import { t } from "../../utils/i18n";

interface Props {
  languages: LanguageEntry[];
}

const { languages } = Astro.props;
---

<section class="reveal mt-20 print:mt-6">
  <h2
    class="mb-10 text-3xl font-bold uppercase tracking-tight text-text-primary sm:text-4xl print:mb-1.5 print:border-b print:border-gray-300 print:pb-0.5 print:text-[10px] print:font-medium print:normal-case print:tracking-widest print:text-black"
    data-i18n="ui.about.languages"
  >
    {t("ui.about.languages")}
  </h2>
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-3 print:flex print:gap-x-6">
    {
      languages.map((lang: LanguageEntry, langIndex: number) => (
        <div class="border-t border-border-primary pt-4 print:border-0 print:pt-0">
          <h3 class="font-medium text-text-primary print:text-[10px] print:text-gray-900">
            {lang.language}
          </h3>
          <p
            class="mt-1 text-sm text-text-muted print:mt-0 print:text-[10px] print:text-gray-500"
            data-i18n={`languages.${langIndex}.fluency`}
          >
            {t(`languages.${langIndex}.fluency` as I18nKey, lang.fluency)}
          </p>
        </div>
      ))
    }
  </div>
</section>
