---
import type { EducationEntry } from "../../types/ui";

interface Props {
  education: EducationEntry[];
}

const { education } = Astro.props;
---

<section class="reveal mt-20 print:mt-6">
  <h2
    class="mb-10 text-3xl font-bold uppercase tracking-tight text-text-primary sm:text-4xl print:mb-1.5 print:border-b print:border-gray-300 print:pb-0.5 print:text-[10px] print:font-medium print:normal-case print:tracking-widest print:text-black"
    data-i18n="ui.about.education"
  >
    Education
  </h2>
  <div class="space-y-6 print:space-y-4">
    {
      education.map((edu: EducationEntry, eduIndex: number) => (
        <div class="border-t border-border-primary pt-4 print:border-0 print:pt-0">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between print:flex-row print:gap-0">
            <div>
              <h3
                class="font-medium text-text-primary print:text-[10px] print:font-semibold print:text-gray-900"
                data-i18n={`education.${eduIndex}.studyType`}
              >
                {edu.studyType}
              </h3>
              <p class="text-sm text-text-secondary print:text-[10px] print:text-gray-600">
                <span data-i18n={`education.${eduIndex}.area`}>{edu.area}</span>{" "}
                <span class="hidden print:inline">— {edu.institution}</span>
              </p>
            </div>
            <span class="whitespace-nowrap text-xs uppercase tracking-widest text-text-muted print:text-[9px] print:text-gray-500">
              {new Date(edu.startDate).getFullYear()} &mdash;{" "}
              {new Date(edu.endDate).getFullYear()}
            </span>
          </div>
          <a
            href={edu.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-secondary underline decoration-text-secondary/40 underline-offset-2 transition-all duration-200 hover:text-text-primary hover:decoration-text-primary print:hidden"
          >
            {edu.institution}
          </a>
        </div>
      ))
    }
  </div>
</section>
