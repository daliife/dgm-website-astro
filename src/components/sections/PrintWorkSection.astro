---
import type { WorkEntry } from "../../types/ui";
import type { I18nKey } from "../../i18n/en";
import { t } from "../../utils/i18n";
import { WORK_DATES_PRINT_CLASSES } from "../../utils/constants";
import WorkDates from "./WorkDates.astro";

interface Props {
  work: WorkEntry[];
}

const { work } = Astro.props;
---

<section class="hidden print:block">
  <h2
    class="print:mb-1.5 print:border-b print:border-gray-300 print:pb-0.5 print:text-[10px] print:font-medium print:uppercase print:tracking-widest print:text-black"
    data-i18n="ui.about.experience"
  >
    {t("ui.about.experience")}
  </h2>
  {
    work.map((job: WorkEntry, jobIndex: number) => (
      <div class="print:mb-5 print:break-inside-avoid">
        <div class="print:flex print:items-baseline print:justify-between">
          <div>
            <span
              class="print:text-[11px] print:font-semibold print:text-black"
              data-i18n={`work.${jobIndex}.position`}
            >
              {t(`work.${jobIndex}.position` as I18nKey, job.position)}
            </span>
            <span class="print:text-[11px] print:text-gray-600">
              {" "}
              — {job.company}
            </span>
          </div>
          <WorkDates
            startDate={job.startDate}
            endDate={job.endDate}
            className={WORK_DATES_PRINT_CLASSES}
          />
        </div>
        {job.summary && (
          <p
            class="print:mt-1.5 print:text-[10px] print:leading-relaxed print:text-gray-600"
            data-i18n={`work.${jobIndex}.summary`}
          >
            {t(`work.${jobIndex}.summary` as I18nKey, job.summary)}
          </p>
        )}
        {job.highlights && job.highlights.length > 0 && (
          <ul class="print:mt-1.5 print:space-y-1">
            {job.highlights.map((h: string, hIndex: number) => (
              <li
                class="before:absolute before:left-0 before:text-gray-400 before:content-['–'] print:relative print:pl-3 print:text-[10px] print:leading-snug print:text-gray-600"
                data-i18n={`work.${jobIndex}.highlights.${hIndex}`}
              >
                {t(`work.${jobIndex}.highlights.${hIndex}` as I18nKey, h)}
              </li>
            ))}
          </ul>
        )}
      </div>
    ))
  }
</section>
