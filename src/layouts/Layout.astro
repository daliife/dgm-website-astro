---
import { LIVE_URL } from "../utils/constants";
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import "@fontsource-variable/inter";
import { ClientRouter } from "astro:transitions";
import { basics, work } from "@cv";
import type { SocialProfile } from "../types/ui";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  hideFooter?: boolean;
}

const {
  title,
  description = "Personal portfolio website of David Gimeno - Software Engineer based in Barcelona",
  image: imageProp,
  type = "website",
  hideFooter = false,
} = Astro.props;

const {
  name,
  lastName,
  label,
  profiles,
  location,
  image: profileImage,
} = basics;
const image =
  imageProp ?? `${LIVE_URL}${profileImage ?? "/david-profile.webp"}`;
const fullName = `${name} ${lastName}`;
const github = (profiles as SocialProfile[])?.find(p => p.network === "Github");
const linkedin = (profiles as SocialProfile[])?.find(
  p => p.network === "Linkedin"
);
const currentJob = work?.[0];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: fullName,
  jobTitle: label,
  description: `${label} based in ${location?.city}, currently working at ${currentJob?.company}`,
  url: LIVE_URL,
  image: `${LIVE_URL}${profileImage ?? "/david-profile.webp"}`,
  sameAs: [github?.url, linkedin?.url].filter(Boolean),
  ...(currentJob && {
    worksFor: {
      "@type": "Organization",
      name: currentJob.company,
      url: currentJob.url,
    },
  }),
  ...(location && {
    address: {
      "@type": "PostalAddress",
      addressLocality: location.city,
      addressCountry: location.countryCode,
    },
  }),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={Astro.url} />

    <!-- SEO Meta Tags -->
    <meta name="author" content="David Gimeno" />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="en" />

    <meta name="generator" content={Astro.generator} />
    <meta
      name="theme-color"
      content="#ffffff"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#0a0a0a"
      media="(prefers-color-scheme: dark)"
    />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="David Gimeno Portfolio" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <title>{title}</title>
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />

    <script is:inline>
      function applyTheme() {
        const saved = localStorage.getItem("theme");
        if (
          saved === "dark" ||
          (!saved && window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      }
      applyTheme();
      document.addEventListener("astro:after-swap", applyTheme);
    </script>
    <ClientRouter />
  </head>
  <body
    class={`bg-bg-primary text-text-primary font-sans ${
      hideFooter
        ? "grid grid-rows-[auto_1fr] min-h-[100vh] relative"
        : "grid grid-rows-[auto_1fr_auto] min-h-[100vh] relative"
    }`}
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-text-primary focus:text-bg-primary focus:rounded-lg focus:shadow-lg focus:outline-none"
    >
      Skip to main content
    </a>

    <Header transition:persist />
    <main id="main-content" class="w-full relative">
      <slot />
    </main>
    {!hideFooter && <Footer />}
    <style is:global>
      :root {
        --text-primary: 23 23 23;
        --text-secondary: 64 64 64;
        --text-muted: 115 115 115;
        --text-accent: 23 23 23;

        --bg-primary: 255 255 255;
        --bg-secondary: 250 250 250;
        --bg-muted: 245 245 245;

        --border-primary: 229 229 229;
        --border-secondary: 212 212 212;
        --border-muted: 163 163 163;
      }

      .dark {
        --text-primary: 250 250 250;
        --text-secondary: 212 212 212;
        --text-muted: 163 163 163;
        --text-accent: 250 250 250;

        --bg-primary: 10 10 10;
        --bg-secondary: 23 23 23;
        --bg-muted: 38 38 38;

        --border-primary: 38 38 38;
        --border-secondary: 64 64 64;
        --border-muted: 115 115 115;
      }

      html {
        scroll-behavior: smooth;
        overflow-y: scroll;
        background-color: rgb(var(--bg-primary));
        color: rgb(var(--text-primary));
        transition:
          background-color 0.3s ease,
          color 0.3s ease;
      }

      body {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
        overflow-x: hidden;
      }

      *,
      *::before,
      *::after {
        transition-property: background-color, border-color, color;
        transition-duration: 0.3s;
        transition-timing-function: ease;
      }

      *:focus-visible {
        outline: 2px solid rgb(var(--text-primary));
        outline-offset: 2px;
        border-radius: 2px;
      }

      /* Scroll reveal */
      .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition:
          opacity 0.6s ease,
          transform 0.6s ease;
      }
      .reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
        .reveal {
          opacity: 1;
          transform: none;
        }
      }
    </style>
    <script>
      document.addEventListener("astro:page-load", () => {
        const prefersReduced = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;
        if (prefersReduced) return;

        const observer = new IntersectionObserver(
          entries => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );

        document
          .querySelectorAll(".reveal")
          .forEach(el => observer.observe(el));
      });
    </script>
  </body>
</html>
